# PetSpot El Sahel — local ↔ online Odoo (copy to .env and fill in)
# Do not commit .env (listed in .gitignore)

# --- Online Odoo (JSON-RPC base URL — no /odoo suffix) ---
ODOO_URL=https://drpaws.ai
ODOO_WEB_URL=https://drpaws.ai/odoo
ODOO_DB=pet_spot_elsahel
ODOO_USERNAME=admin
ODOO_PASSWORD=admin
ODOO_API_KEY=your-api-key-here
ODOO_API_KEY_2=your-second-api-key-here
ODOO_VERSION=19

# --- Local Odoo ---
LOCAL_ODOO_URL=http://odoo19.local:8027
LOCAL_ODOO_DB=pet_spot_elsahel
LOCAL_ODOO_USERNAME=admin
LOCAL_ODOO_PASSWORD=admin

WEBSITE_URL=https://drpaws.ai/odoo
