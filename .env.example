# Odoo.sh — veterinarian_19 (copy to .env and fill in)
# Do not commit .env (listed in .gitignore)

ODOO_URL=https://your-instance.odoo.com
ODOO_WEB_URL=https://your-instance.odoo.com/odoo
ODOO_DB=your-database-name
ODOO_USERNAME=your@email.com
ODOO_PASSWORD=your-password
ODOO_API_KEY=your-api-key
ODOO_VERSION=19

# Optional: JSON-RPC endpoints (derived from ODOO_URL if unset)
# ODOO_XMLRPC_URL=${ODOO_URL}/xmlrpc/2
# ODOO_JSONRPC_URL=${ODOO_URL}/jsonrpc
