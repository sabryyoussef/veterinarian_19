# Odoo 19 — PetSpot El Sahel (copy to .env and fill in)
# Do not commit .env (listed in .gitignore)

# Tailscale (recommended — master)
ODOO_URL=http://100.76.217.35:8027
ODOO_WEB_URL=http://master:8027
ODOO_DB=pet_spot_elsahel
ODOO_USERNAME=admin
ODOO_PASSWORD=admin
ODOO_API_KEY=your-api-key
ODOO_VERSION=19

# JSON-RPC / XML-RPC (derived from ODOO_URL if unset)
ODOO_JSONRPC_URL=http://100.76.217.35:8027/jsonrpc
ODOO_XMLRPC_URL=http://100.76.217.35:8027/xmlrpc/2
ODOO_TAILSCALE_HOST=master
ODOO_TAILSCALE_IP=100.76.217.35

# Local fallback when remote port not reachable
ODOO_LOCAL_URL=http://127.0.0.1:8027
ODOO_LOCAL_JSONRPC_URL=http://127.0.0.1:8027/jsonrpc

# Test: python3 scripts/test_odoo_connection.py
