<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dev_github_app_installation_tree" model="ir.ui.view">
        <field name="name">dev.github.app.installation.tree</field>
        <field name="model">dev.github.app.installation</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="app_role"/>
                <field name="app_slug"/>
                <field name="app_id"/>
                <field name="installation_id"/>
                <field name="selected_repositories_only"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_dev_github_app_installation_form" model="ir.ui.view">
        <field name="name">dev.github.app.installation.form</field>
        <field name="model">dev.github.app.installation</field>
        <field name="arch" type="xml">
            <form string="GitHub App Installation">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="app_role"/>
                        <field name="app_slug"/>
                        <field name="app_id"/>
                        <field name="installation_id"/>
                        <field name="selected_repositories_only"/>
                        <field name="allow_all_repositories"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="permission_summary"/>
                    </group>
                    <field name="allowlist_ids">
                        <list editable="bottom">
                            <field name="github_repository"/>
                            <field name="installation_repository_id"/>
                            <field name="credential_profile_reference"/>
                            <field name="credential_broker_reference"/>
                            <field name="active"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_dev_github_app_installation" model="ir.actions.act_window">
        <field name="name">GitHub App Installations</field>
        <field name="res_model">dev.github.app.installation</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_dev_github_repository_allowlist" model="ir.actions.act_window">
        <field name="name">Repository Allowlists</field>
        <field name="res_model">dev.github.repository.allowlist</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
