<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dev_launch_wizard_form" model="ir.ui.view">
        <field name="name">dev.launch.wizard.form</field>
        <field name="model">dev.launch.wizard</field>
        <field name="arch" type="xml">
            <form string="Explicit Cursor Remote SSH Launcher">
                <sheet>
                    <div class="alert alert-warning" role="alert" invisible="not drift_warning">
                        <strong>Review Git drift before continuing:</strong>
                        <field name="drift_warning" nolabel="1"/>
                    </div>
                    <div class="alert alert-info" role="alert">
                        <field name="safety_note" nolabel="1"/>
                    </div>
                    <group>
                        <field name="session_id"/>
                    </group>
                    <notebook>
                        <page string="Ubuntu / Linux">
                            <p>Download the workspace below, then copy this fixed command into a local terminal:</p>
                            <field name="command_linux" nolabel="1" readonly="1"/>
                        </page>
                        <page string="Windows PowerShell">
                            <p>Download the workspace below, then copy this fixed command into local PowerShell:</p>
                            <field name="command_windows" nolabel="1" readonly="1"/>
                        </page>
                        <page string="Sanitized Manifest">
                            <field name="manifest_json" nolabel="1" readonly="1"/>
                        </page>
                    </notebook>
                    <field name="workspace_file" invisible="1"/>
                    <field name="workspace_filename" invisible="1"/>
                    <field name="manifest_file" invisible="1"/>
                    <field name="manifest_filename" invisible="1"/>
                </sheet>
                <footer>
                    <button name="action_download_workspace" type="object" string="Download Remote Workspace (Explicit Open)" class="btn-secondary"/>
                    <button name="action_download_manifest" type="object" string="Download Manifest"/>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
