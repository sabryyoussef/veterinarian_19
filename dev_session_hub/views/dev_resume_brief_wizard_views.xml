<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dev_resume_brief_wizard_form" model="ir.ui.view">
        <field name="name">dev.resume.brief.wizard.form</field>
        <field name="model">dev.resume.brief.wizard</field>
        <field name="arch" type="xml">
            <form string="Resume Development Work">
                <group>
                    <field name="session_id"/>
                    <field name="work_item_id"/>
                    <field name="context_revision"/>
                </group>
                <div class="alert alert-warning" role="alert" invisible="not drift_warning">
                    <strong>Git drift requires review:</strong>
                    <field name="drift_warning" nolabel="1"/>
                </div>
                <field name="resume_brief" nolabel="1" widget="text"/>
                <footer>
                    <button name="action_continue_to_launcher"
                            type="object"
                            string="Continue to Cursor Launcher"
                            class="btn-primary"/>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
