<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dev_session_search" model="ir.ui.view">
        <field name="name">dev.session.search</field>
        <field name="model">dev.session</field>
        <field name="arch" type="xml">
            <search string="Recent Development Work">
                <field name="name"/>
                <field name="project_id"/>
                <field name="work_item_id"/>
                <field name="task_link_id"/>
                <field name="environment_id"/>
                <field name="machine_id"/>
                <field name="client_id"/>
                <field name="state"/>
                <filter name="active" string="Active" domain="[('state', 'in', ['started', 'in_progress', 'resumed'])]"/>
                <filter name="paused" string="Paused" domain="[('state', '=', 'paused')]"/>
                <filter name="my_sessions" string="My Sessions" domain="[('user_id', '=', uid)]"/>
                <group name="group_by">
                    <filter name="group_project" string="Project" context="{'group_by': 'project_id'}"/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                    <filter name="group_client" string="Client" context="{'group_by': 'client_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_dev_session_list" model="ir.ui.view">
        <field name="name">dev.session.list</field>
        <field name="model">dev.session</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'completed'"
                  decoration-warning="state == 'paused'"
                  decoration-danger="state in ('blocked', 'abandoned')"
                  default_order="write_date desc">
                <field name="name"/>
                <field name="project_id"/>
                <field name="work_item_id"/>
                <field name="task_link_id"/>
                <field name="environment_id"/>
                <field name="machine_id"/>
                <field name="git_branch_snapshot"/>
                <field name="state"/>
                <field name="client_id"/>
                <field name="active_client_id"/>
                <field name="write_date" string="Last Activity"/>
            </list>
        </field>
    </record>

    <record id="view_dev_session_kanban" model="ir.ui.view">
        <field name="name">dev.session.kanban</field>
        <field name="model">dev.session</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="project_id"/>
                <field name="work_item_id"/>
                <field name="task_link_id"/>
                <field name="environment_id"/>
                <field name="machine_id"/>
                <field name="git_branch_snapshot"/>
                <field name="state"/>
                <field name="client_id"/>
                <field name="write_date"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <strong><field name="name"/></strong>
                            <div><field name="project_id"/> · <field name="environment_id"/></div>
                            <div><field name="work_item_id"/></div>
                            <div><field name="task_link_id"/></div>
                            <div><field name="machine_id"/> · <field name="client_id"/></div>
                            <div t-if="record.git_branch_snapshot.raw_value">
                                Branch: <field name="git_branch_snapshot"/>
                            </div>
                            <small>Last activity: <field name="write_date"/></small>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_dev_session_form" model="ir.ui.view">
        <field name="name">dev.session.form</field>
        <field name="model">dev.session</field>
        <field name="arch" type="xml">
            <form string="Development Session">
                <header>
                    <button name="action_start" type="object" string="Start &amp; Launch" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_mark_in_progress" type="object" string="Mark In Progress" class="btn-primary" invisible="state not in ('started', 'resumed')"/>
                    <button name="action_pause" type="object" string="Pause" invisible="state not in ('started', 'in_progress', 'resumed')"/>
                    <button name="action_resume" type="object" string="Resume &amp; Launch" class="btn-primary" invisible="state not in ('paused', 'blocked')"/>
                    <button name="action_open_launcher" type="object" string="Open Launcher" invisible="state not in ('started', 'in_progress', 'resumed')"/>
                    <button name="action_checkpoint_milestone" type="object" string="Checkpoint Milestone" invisible="not work_item_id or state not in ('started', 'in_progress', 'resumed')"/>
                    <button name="action_checkpoint_agent_handoff" type="object" string="Checkpoint Handoff" invisible="not work_item_id or state not in ('started', 'in_progress', 'paused', 'resumed', 'blocked')"/>
                    <button name="action_complete" type="object" string="Complete" class="btn-secondary" invisible="state not in ('in_progress', 'resumed')"/>
                    <button name="action_block" type="object" string="Block" invisible="state not in ('started', 'in_progress', 'paused', 'resumed')"/>
                    <button name="action_abandon" type="object" string="Abandon" invisible="state in ('completed', 'abandoned')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,started,in_progress,paused,resumed,completed"/>
                </header>
                <sheet>
                    <div class="alert alert-warning" role="alert" invisible="not drift_warning">
                        <strong>Git drift detected:</strong>
                        <field name="drift_warning" nolabel="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="state != 'draft'"/>
                            <field name="user_id" readonly="state != 'draft'"/>
                            <field name="client_id" readonly="state not in ('draft', 'paused', 'blocked')"/>
                            <field name="active_client_id" readonly="1"/>
                            <field name="work_item_id" domain="[('dev_project_id', '=', project_id)]" readonly="state != 'draft'"/>
                            <field name="task_link_id" domain="[('project_id', '=', project_id)]" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="project_id" readonly="state != 'draft'"/>
                            <field name="environment_id" domain="[('project_id', '=', project_id)]" readonly="state != 'draft'"/>
                            <field name="machine_id" readonly="state != 'draft'"/>
                            <field name="repository_id" domain="[('project_id', '=', project_id)]" readonly="state != 'draft'"/>
                            <field name="working_directory" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Git Snapshot">
                            <group>
                                <field name="git_branch_snapshot" readonly="1"/>
                                <field name="git_head_snapshot" readonly="1"/>
                                <field name="dirty_state_summary" readonly="1"/>
                            </group>
                            <div class="alert alert-info" role="alert">
                                Dev Hub reads Git metadata only. It does not switch, reset, clean, commit, push, or copy file contents/diffs.
                            </div>
                        </page>
                        <page string="Context &amp; Notes">
                            <field name="last_note" placeholder="Sanitized handoff note. Do not enter credentials, tokens, prompts, diffs, or environment values."/>
                            <field name="cursor_agent_thread_id"/>
                        </page>
                        <page string="Manifest">
                            <group>
                                <field name="manifest_revision" readonly="1"/>
                            </group>
                            <field name="manifest_json" readonly="1" widget="text"/>
                        </page>
                        <page string="Lifecycle">
                            <group>
                                <field name="started_at" readonly="1"/>
                                <field name="paused_at" readonly="1"/>
                                <field name="resumed_at" readonly="1"/>
                                <field name="completed_at" readonly="1"/>
                            </group>
                            <field name="event_ids" readonly="1">
                                <list create="0" edit="0" delete="0">
                                    <field name="timestamp"/>
                                    <field name="state_transition"/>
                                    <field name="actor_id"/>
                                    <field name="client_id"/>
                                    <field name="reason"/>
                                    <field name="git_snapshot"/>
                                    <field name="correlation_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_dev_session" model="ir.actions.act_window">
        <field name="name">Recent Work</field>
        <field name="res_model">dev.session</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_dev_session_search"/>
        <field name="context">{'search_default_my_sessions': 1}</field>
    </record>

    <record id="action_dev_session_active" model="ir.actions.act_window">
        <field name="name">Active Sessions</field>
        <field name="res_model">dev.session</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ['started', 'in_progress', 'resumed'])]</field>
    </record>

    <record id="action_dev_session_paused" model="ir.actions.act_window">
        <field name="name">Paused Sessions</field>
        <field name="res_model">dev.session</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'paused')]</field>
    </record>
</odoo>
