# Copy to .env and adjust before: docker compose up -d
# Generate a strong key: openssl rand -hex 16

SERVER_NAME=petspot-evolution
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=http://127.0.0.1:8099

AUTHENTICATION_API_KEY=CHANGE_ME_PETSPOT_EVOLUTION_KEY
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true

POSTGRES_DATABASE=evolution
POSTGRES_USERNAME=evolution
POSTGRES_PASSWORD=evolution

DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:evolution@evolution-postgres:5432/evolution?schema=evolution_api
DATABASE_CONNECTION_CLIENT_NAME=petspot_evolution

CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/1
CACHE_REDIS_PREFIX_KEY=petspot_evolution

# Push delivery/read + inbound events to local Odoo (pet_spot_elsahel on :8027)
WEBHOOK_GLOBAL_ENABLED=true
WEBHOOK_GLOBAL_URL=http://host.docker.internal:8027/bridge/evolution/webhook
WEBHOOK_EVENTS_MESSAGES_UPDATE=true
WEBHOOK_EVENTS_MESSAGES_UPSERT=true
WEBHOOK_EVENTS_CONNECTION_UPDATE=true

CONFIG_SESSION_PHONE_CLIENT=PetSpot El Sahel
CONFIG_SESSION_PHONE_NAME=Chrome
LOG_LEVEL=ERROR,WARN,INFO,WEBHOOKS
CORS_ORIGIN=*
