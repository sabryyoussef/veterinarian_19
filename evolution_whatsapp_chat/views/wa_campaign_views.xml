<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════════
         WhatsApp Campaign Views
    ════════════════════════════════════════════════════════════════════════ -->

    <!-- Form View -->
    <record id="view_wa_campaign_form" model="ir.ui.view">
        <field name="name">wa.campaign.form</field>
        <field name="model">wa.campaign</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Campaign">
                <header>
                    <button name="action_load_recipients" string="📋 Load Recipients"
                            type="object" class="btn-primary"
                            invisible="state not in ['draft', 'scheduled']"/>
                    <button name="action_generate_lines" string="🔄 Regenerate Lines"
                            type="object" class="btn-secondary"
                            invisible="state not in ['draft', 'scheduled']"
                            confirm="This will clear and regenerate all recipient lines. Continue?"/>
                    <button name="action_start_campaign" string="▶ Start Campaign"
                            type="object" class="btn-success"
                            invisible="state not in ['draft', 'scheduled', 'paused']"/>
                    <button name="action_pause_campaign" string="⏸ Pause"
                            type="object" class="btn-warning"
                            invisible="state != 'running'"/>
                    <button name="action_resume_campaign" string="▶ Resume"
                            type="object" class="btn-success"
                            invisible="state != 'paused'"/>
                    <button name="action_retry_failed" string="🔁 Retry Failed"
                            type="object" class="btn-info"
                            invisible="failed_count == 0"/>
                    <button name="action_cancel_campaign" string="Cancel Campaign"
                            type="object" class="btn-danger"
                            invisible="state in ['completed', 'cancelled']"
                            confirm="Are you sure you want to cancel this campaign?"/>
                    <button name="action_clone_campaign" string="📋 Clone"
                            type="object" class="btn-secondary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,scheduled,running,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_lines" type="object"
                                class="oe_stat_button" icon="fa-users">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="total_count"/>
                                </span>
                                <span class="o_stat_text">Recipients</span>
                            </div>
                        </button>
                        <button name="action_view_lines" type="object"
                                class="oe_stat_button" icon="fa-check-circle"
                                style="color: green;">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="sent_count"/>
                                </span>
                                <span class="o_stat_text">Sent</span>
                            </div>
                        </button>
                        <button name="action_view_lines" type="object"
                                class="oe_stat_button" icon="fa-eye"
                                style="color: blue;">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="read_count"/>
                                </span>
                                <span class="o_stat_text">Read</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Summer Promotion 2026"/>
                        </h1>
                        <field name="description" placeholder="Campaign description..."/>
                    </div>

                    <group>
                        <group string="Targeting">
                            <field name="target_model" widget="radio"/>
                            <field name="partner_ids" widget="many2many_tags"
                                   invisible="target_model != 'res.partner'"
                                   options="{'color_field': 'color', 'no_create': True}"/>
                            <field name="lead_ids" widget="many2many_tags"
                                   invisible="target_model != 'crm.lead'"
                                   options="{'no_create': True}"/>
                            <field name="filter_domain" placeholder="e.g. [('country_id.code', '=', 'EG')]"/>
                        </group>
                        <group string="Schedule &amp; Delivery">
                            <field name="send_mode" widget="radio"/>
                            <field name="scheduled_date"
                                   invisible="send_mode != 'scheduled'"/>
                            <field name="delay_between"
                                   invisible="send_mode != 'immediate'"/>
                        </group>
                    </group>

                    <group string="Anti-Duplicate Settings">
                        <field name="check_duplicates"/>
                        <field name="min_days_between"
                               invisible="not check_duplicates"/>
                    </group>

                    <notebook>
                        <page string="Message" name="message">
                            <group>
                                <field name="template_id"
                                       options="{'no_create': True}"/>
                                <field name="personalise"/>
                            </group>
                            <field name="message" nolabel="1" widget="text"
                                   placeholder="Your message here...&#10;&#10;Use placeholders:&#10;{name} - Full name&#10;{first} - First name&#10;{company} - Company&#10;{phone} - Phone number"/>
                            <div class="alert alert-info mt-3" role="status">
                                <b>ℹ️ Placeholders:</b> {name}, {first}, {company}, {phone}
                            </div>
                        </page>

                        <page string="Attachments" name="attachments">
                            <field name="attachment_ids" widget="many2many_binary" nolabel="1"/>
                        </page>

                        <page string="Recipients" name="recipients">
                            <field name="campaign_line_ids" nolabel="1" 
                                   context="{'tree_view_ref': 'evolution_whatsapp_chat.view_wa_campaign_line_tree'}"/>
                        </page>

                        <page string="Statistics" name="stats">
                            <group>
                                <group string="Delivery Stats">
                                    <field name="total_count"/>
                                    <field name="pending_count"/>
                                    <field name="sent_count"/>
                                    <field name="delivered_count"/>
                                    <field name="read_count"/>
                                    <field name="failed_count"/>
                                    <field name="skipped_count"/>
                                </group>
                                <group string="Performance">
                                    <field name="success_rate" widget="percentage"/>
                                    <field name="read_rate" widget="percentage"/>
                                    <field name="progress" widget="progressbar"/>
                                </group>
                                <group string="Timeline">
                                    <field name="create_date"/>
                                    <field name="start_date"/>
                                    <field name="completed_date"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_wa_campaign_tree" model="ir.ui.view">
        <field name="name">wa.campaign.tree</field>
        <field name="model">wa.campaign</field>
        <field name="arch" type="xml">
            <list string="WhatsApp Campaigns"
                  decoration-success="state == 'completed'"
                  decoration-info="state == 'running'"
                  decoration-muted="state in ['cancelled', 'draft']">
                <field name="name"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'completed'"
                       decoration-info="state == 'running'"
                       decoration-warning="state in ['scheduled', 'paused']"
                       decoration-danger="state == 'cancelled'"/>
                <field name="target_model"/>
                <field name="total_count"/>
                <field name="sent_count"/>
                <field name="read_count"/>
                <field name="success_rate" widget="percentage"/>
                <field name="progress" widget="progressbar"/>
                <field name="scheduled_date" optional="hide"/>
                <field name="start_date" optional="hide"/>
                <field name="completed_date" optional="hide"/>
                <field name="create_date" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_wa_campaign_kanban" model="ir.ui.view">
        <field name="name">wa.campaign.kanban</field>
        <field name="model">wa.campaign</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <field name="state"/>
                <field name="total_count"/>
                <field name="sent_count"/>
                <field name="success_rate"/>
                <field name="progress"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <span class="badge" t-attf-class="badge-{{state == 'completed' ? 'success' : state == 'running' ? 'info' : 'secondary'}}">
                                    <field name="state"/>
                                </span>
                            </div>
                            <div class="o_kanban_record_body">
                                <div class="row mt-2">
                                    <div class="col-6">
                                        <strong><field name="total_count"/></strong> Recipients
                                    </div>
                                    <div class="col-6">
                                        <strong><field name="sent_count"/></strong> Sent
                                    </div>
                                </div>
                                <div class="mt-2">
                                    <field name="progress" widget="progressbar" invisible="progress == 0"/>
                                    <span t-if="record.progress.raw_value > 0">
                                        <t t-esc="Math.round(record.progress.raw_value)"/>% Complete
                                    </span>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom mt-2">
                                <div class="oe_kanban_bottom_left">
                                    <field name="create_date" widget="date"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <span t-if="record.success_rate.raw_value > 0" class="badge badge-success">
                                        <t t-esc="Math.round(record.success_rate.raw_value)"/>% Success
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_wa_campaign_pivot" model="ir.ui.view">
        <field name="name">wa.campaign.pivot</field>
        <field name="model">wa.campaign</field>
        <field name="arch" type="xml">
            <pivot string="Campaign Analysis">
                <field name="state" type="row"/>
                <field name="total_count" type="measure"/>
                <field name="sent_count" type="measure"/>
                <field name="delivered_count" type="measure"/>
                <field name="read_count" type="measure"/>
                <field name="failed_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_wa_campaign_graph" model="ir.ui.view">
        <field name="name">wa.campaign.graph</field>
        <field name="model">wa.campaign</field>
        <field name="arch" type="xml">
            <graph string="Campaign Statistics" type="bar">
                <field name="name"/>
                <field name="sent_count" type="measure"/>
                <field name="read_count" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_wa_campaign_search" model="ir.ui.view">
        <field name="name">wa.campaign.search</field>
        <field name="model">wa.campaign</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="description"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="scheduled" string="Scheduled" domain="[('state', '=', 'scheduled')]"/>
                <filter name="running" string="Running" domain="[('state', '=', 'running')]"/>
                <filter name="completed" string="Completed" domain="[('state', '=', 'completed')]"/>
                <separator/>
                <filter name="contacts" string="Contacts" domain="[('target_model', '=', 'res.partner')]"/>
                <filter name="leads" string="Leads" domain="[('target_model', '=', 'crm.lead')]"/>
                <separator/>
                <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                <filter name="group_target" string="Target Type" context="{'group_by': 'target_model'}"/>
                <filter name="group_create_date" string="Created Date" context="{'group_by': 'create_date'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_wa_campaign" model="ir.actions.act_window">
        <field name="name">WhatsApp Campaigns</field>
        <field name="res_model">wa.campaign</field>
        <field name="view_mode">kanban,list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_wa_campaign_search"/>
        <field name="context">{'search_default_running': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first WhatsApp Campaign
            </p>
            <p>
                Campaigns let you send targeted messages to multiple contacts<br/>
                with full status tracking and anti-duplicate protection.
            </p>
        </field>
    </record>

    <!-- Recipient Wizard View -->
    <record id="view_wa_campaign_recipient_wizard_form" model="ir.ui.view">
        <field name="name">wa.campaign.recipient.wizard.form</field>
        <field name="model">wa.campaign.recipient.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Recipients">
                <sheet>
                    <group>
                        <field name="campaign_id" invisible="1"/>
                        <field name="target_model" widget="radio"/>
                        <field name="use_domain"/>
                    </group>

                    <group invisible="use_domain">
                        <field name="partner_ids" nolabel="1" widget="many2many"
                               invisible="target_model != 'res.partner'">
                            <list>
                                <field name="name"/>
                                <field name="phone"/>
                                <field name="email"/>
                            </list>
                        </field>
                        <field name="lead_ids" nolabel="1" widget="many2many"
                               invisible="target_model != 'crm.lead'">
                            <list>
                                <field name="name"/>
                                <field name="partner_name"/>
                                <field name="phone"/>
                                <field name="email_from"/>
                            </list>
                        </field>
                    </group>

                    <group invisible="not use_domain">
                        <field name="filter_domain" nolabel="1" widget="text"
                               placeholder="[('country_id.code', '=', 'EG'), ('active', '=', True)]"/>
                    </group>

                    <div class="alert alert-info mt-3" role="status">
                        <h4>Will add: <strong><field name="preview_count"/></strong> recipients</h4>
                    </div>
                </sheet>
                <footer>
                    <button name="action_add_recipients" string="Add Recipients"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
