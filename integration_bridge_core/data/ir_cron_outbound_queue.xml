<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_process_outbound_queue" model="ir.cron">
            <field name="name">Integration Bridge: Process Outbound Queue</field>
            <field name="model_id" ref="model_integration_outbound_queue"/>
            <field name="state">code</field>
            <field name="code">model.process_pending_messages(limit=50)</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
            <field name="priority">10</field>
        </record>

        <record id="ir_cron_cleanup_old_logs" model="ir.cron">
            <field name="name">Integration Bridge: Cleanup Old Logs</field>
            <field name="model_id" ref="model_integration_bridge_log"/>
            <field name="state">code</field>
            <field name="code">model.cleanup_old_logs(days=90)</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
            <field name="priority">50</field>
        </record>
    </data>
</odoo>
