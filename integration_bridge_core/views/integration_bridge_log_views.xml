<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_integration_bridge_log_tree" model="ir.ui.view">
        <field name="name">integration.bridge.log.tree</field>
        <field name="model">integration.bridge.log</field>
        <field name="arch" type="xml">
            <list string="Integration Logs">
                <field name="create_date" widget="datetime"/>
                <field name="name"/>
                <field name="direction" widget="badge"
                       decoration-info="direction == 'inbound'"
                       decoration-success="direction == 'outbound'"/>
                <field name="platform" widget="badge"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'success'"
                       decoration-danger="status == 'failed'"
                       decoration-warning="status == 'pending'"/>
                <field name="endpoint"/>
                <field name="external_id" optional="hide"/>
                <field name="http_status" optional="show"/>
                <field name="duration_ms" optional="hide"/>
                <field name="remote_ip" optional="hide"/>
                <field name="retry_count" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_integration_bridge_log_form" model="ir.ui.view">
        <field name="name">integration.bridge.log.form</field>
        <field name="model">integration.bridge.log</field>
        <field name="arch" type="xml">
            <form string="Integration Log">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="pending,success,failed"/>
                    <button name="action_retry" string="Retry" type="object"
                            invisible="status != 'failed' or direction != 'outbound'"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Integration Details">
                            <field name="direction" widget="badge"/>
                            <field name="platform" widget="badge"/>
                            <field name="endpoint"/>
                            <field name="external_id"/>
                            <field name="http_status"/>
                            <field name="duration_ms"/>
                        </group>
                        <group string="Related Record">
                            <field name="related_model"/>
                            <field name="related_res_id"/>
                            <field name="retry_count"/>
                            <field name="remote_ip"/>
                            <field name="user_agent"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Request Payload">
                            <field name="request_payload" widget="ace"
                                   options="{'mode': 'json'}"/>
                        </page>
                        <page string="Response Payload">
                            <field name="response_payload" widget="ace"
                                   options="{'mode': 'json'}"/>
                        </page>
                        <page string="Error Details" invisible="status != 'failed'">
                            <field name="error_message"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_integration_bridge_log_search" model="ir.ui.view">
        <field name="name">integration.bridge.log.search</field>
        <field name="model">integration.bridge.log</field>
        <field name="arch" type="xml">
            <search string="Integration Logs">
                <field name="name"/>
                <field name="external_id"/>
                <field name="endpoint"/>
                <field name="remote_ip"/>
                <filter string="Inbound"   name="filter_inbound"
                        domain="[('direction','=','inbound')]"/>
                <filter string="Outbound"  name="filter_outbound"
                        domain="[('direction','=','outbound')]"/>
                <separator/>
                <filter string="Success"   name="filter_success"
                        domain="[('status','=','success')]"/>
                <filter string="Failed"    name="filter_failed"
                        domain="[('status','=','failed')]"/>
                <filter string="Pending"   name="filter_pending"
                        domain="[('status','=','pending')]"/>
                <separator/>
                <filter string="Chatwoot"  name="filter_chatwoot"
                        domain="[('platform','=','chatwoot')]"/>
                <filter string="Evolution" name="filter_evolution"
                        domain="[('platform','=','evolution')]"/>
                <filter string="n8n"       name="filter_n8n"
                        domain="[('platform','=','n8n')]"/>
                <filter string="Today"     name="filter_today"
                        domain="[('create_date','&gt;=',(context_today()).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="Group by Platform"  name="group_by_platform"
                        context="{'group_by':'platform'}"/>
                <filter string="Group by Direction" name="group_by_direction"
                        context="{'group_by':'direction'}"/>
                <filter string="Group by Status"    name="group_by_status"
                        context="{'group_by':'status'}"/>
            </search>
        </field>
    </record>

    <record id="action_integration_bridge_log" model="ir.actions.act_window">
        <field name="name">Integration Logs</field>
        <field name="res_model">integration.bridge.log</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No integration logs yet</p>
            <p>Logs are created automatically when external platforms call the bridge API.</p>
        </field>
    </record>
</odoo>
