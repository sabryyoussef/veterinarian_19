# LinkedIn Developer App — https://www.linkedin.com/developers/
# Copy to .env and paste your new app credentials (do not commit .env)

LINKEDIN_CLIENT_ID=your-client-id-here
LINKEDIN_CLIENT_SECRET=your-client-secret-here

# Optional — OAuth redirect base (HTTPS in production; local dev example below)
LINKEDIN_PUBLIC_BASE_URL=http://127.0.0.1:8027
# Company page only — numeric id from linkedin.com/company/129944345/
LINKEDIN_ORGANIZATION_ID=129944345

# Connect scopes — add w_organization_social ONLY after Community Management API is Approved
LINKEDIN_OAUTH_SCOPES=openid profile w_member_social
# LINKEDIN_OAUTH_SCOPES=openid profile w_member_social w_organization_social

# --- Test app (optional second linkedin.account) ---
# LINKEDIN_TEST_CLIENT_ID=your-test-client-id
# LINKEDIN_TEST_CLIENT_SECRET=your-test-client-secret
# LINKEDIN_TEST_ACCOUNT_NAME=PetSpot LinkedIn (Test)
# LINKEDIN_TEST_EMAIL=vetdrughouse@gmail.com
# LINKEDIN_TEST_ORGANIZATION_ID=
# LINKEDIN_TEST_OAUTH_SCOPES=openid profile w_member_social

# Shared
ODOO_URL=http://127.0.0.1:8027
ODOO_DB=pet_spot_elsahel
ODOO_USERNAME=admin
ODOO_PASSWORD=admin

# Redirect URI registered in LinkedIn app must match:
#   {LINKEDIN_PUBLIC_BASE_URL}/linkedin_connector/callback?db={ODOO_DB}
# Example local:
#   http://127.0.0.1:8027/linkedin_connector/callback?db=pet_spot_elsahel
