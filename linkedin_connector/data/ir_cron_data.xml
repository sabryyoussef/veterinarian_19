<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ir_cron_publish_scheduled_posts" model="ir.cron">
        <field name="name">LinkedIn: Publish Scheduled Posts</field>
        <field name="model_id" ref="model_linkedin_post"/>
        <field name="state">code</field>
        <field name="code">model._cron_publish_scheduled()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_refresh_feed" model="ir.cron">
        <field name="name">LinkedIn: Refresh Feed</field>
        <field name="model_id" ref="model_linkedin_stream_post"/>
        <field name="state">code</field>
        <field name="code">model._cron_refresh_feed()</field>
        <field name="interval_number">30</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_sync_messages" model="ir.cron">
        <field name="name">LinkedIn: Sync Messages</field>
        <field name="model_id" ref="model_linkedin_conversation"/>
        <field name="state">code</field>
        <field name="code">model._cron_sync_messages()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>

</odoo>
