<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- CONVERSATION LIST -->
    <record id="view_linkedin_conversation_list" model="ir.ui.view">
        <field name="name">linkedin.conversation.list</field>
        <field name="model">linkedin.conversation</field>
        <field name="arch" type="xml">
            <list decoration-info="unread_count > 0">
                <field name="account_id"/>
                <field name="display_name"/>
                <field name="last_message"/>
                <field name="last_activity_at"/>
                <field name="unread_count" string="Unread"/>
                <button name="action_load_messages" type="object"
                        string="Load Messages" icon="fa-refresh"/>
            </list>
        </field>
    </record>

    <!-- CONVERSATION FORM -->
    <record id="view_linkedin_conversation_form" model="ir.ui.view">
        <field name="name">linkedin.conversation.form</field>
        <field name="model">linkedin.conversation</field>
        <field name="arch" type="xml">
            <form string="LinkedIn Conversation">
                <header>
                    <button name="action_load_messages" type="object"
                            string="Refresh Messages" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <field name="account_id" readonly="1"/>
                        <field name="display_name" readonly="1"/>
                        <field name="last_activity_at" readonly="1"/>
                        <field name="unread_count" readonly="1"/>
                    </group>
                    <field name="message_ids" mode="list" nolabel="1">
                        <list>
                            <field name="sent_at"/>
                            <field name="direction" widget="badge"
                                   decoration-info="direction == 'in'"
                                   decoration-success="direction == 'out'"/>
                            <field name="sender_name"/>
                            <field name="body"/>
                            <button name="action_reply" type="object"
                                    string="Reply" icon="fa-reply"
                                    invisible="direction != 'in'"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- MESSAGE REPLY WIZARD -->
    <record id="view_linkedin_message_reply_form" model="ir.ui.view">
        <field name="name">linkedin.message.reply.form</field>
        <field name="model">linkedin.message.reply</field>
        <field name="arch" type="xml">
            <form string="Reply to Message">
                <group>
                    <field name="conversation_id" readonly="1"/>
                    <field name="body" widget="text" placeholder="Write your reply…"/>
                </group>
                <footer>
                    <button name="action_send" type="object" string="Send" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="view_linkedin_conversation_search" model="ir.ui.view">
        <field name="name">linkedin.conversation.search</field>
        <field name="model">linkedin.conversation</field>
        <field name="arch" type="xml">
            <search>
                <field name="display_name" string="Participants"/>
                <field name="account_id"/>
                <filter name="unread" string="Unread" domain="[('unread_count','>',0)]"/>
                <separator/>
                <filter name="group_account" string="Account" context="{'group_by': 'account_id'}"/>
            </search>
        </field>
    </record>

    <!-- ACTIONS -->
    <record id="action_linkedin_conversation" model="ir.actions.act_window">
        <field name="name">Messages</field>
        <field name="res_model">linkedin.conversation</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
