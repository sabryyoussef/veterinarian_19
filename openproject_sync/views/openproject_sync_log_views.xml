<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_openproject_sync_log_list" model="ir.ui.view">
        <field name="name">openproject.sync.log.list</field>
        <field name="model">openproject.sync.log</field>
        <field name="arch" type="xml">
            <list create="0" edit="0">
                <field name="create_date"/>
                <field name="name"/>
                <field name="operation"/>
                <field name="direction"/>
                <field name="state"
                         decoration-success="state == 'ok'"
                         decoration-warning="state == 'warning'"
                         decoration-danger="state in ('error', 'conflict')"/>
                <field name="backend_id"/>
                <field name="project_map_id"/>
                <field name="task_id"/>
                <field name="op_work_package_id"/>
                <field name="message"/>
            </list>
        </field>
    </record>

    <record id="view_openproject_sync_log_form" model="ir.ui.view">
        <field name="name">openproject.sync.log.form</field>
        <field name="model">openproject.sync.log</field>
        <field name="arch" type="xml">
            <form create="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="operation"/>
                            <field name="direction"/>
                            <field name="state"/>
                            <field name="create_date"/>
                        </group>
                        <group>
                            <field name="backend_id"/>
                            <field name="project_map_id"/>
                            <field name="task_id"/>
                            <field name="op_work_package_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="message"/>
                        <field name="details"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_openproject_sync_log" model="ir.actions.act_window">
        <field name="name">Sync Logs</field>
        <field name="res_model">openproject.sync.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
