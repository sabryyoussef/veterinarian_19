<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_openproject_task_realign_wizard_form" model="ir.ui.view">
        <field name="name">openproject.task.realign.wizard.form</field>
        <field name="model">openproject.task.realign.wizard</field>
        <field name="arch" type="xml">
            <form string="Realign Tasks to OpenProject Projects">
                <header>
                    <button name="action_build_audit" type="object" string="Build Audit" class="btn-primary"/>
                    <button name="action_apply" type="object" string="Apply Changes"
                            class="btn-secondary" invisible="dry_run"
                            confirm="Move Odoo tasks to their mapped OpenProject projects?"/>
                </header>
                <sheet>
                    <group>
                        <field name="backend_id"/>
                        <field name="dry_run"/>
                        <field name="state" invisible="1"/>
                    </group>
                    <group invisible="not summary">
                        <field name="summary" nolabel="1" colspan="2"/>
                    </group>
                    <notebook>
                        <page string="Audit Lines">
                            <field name="line_ids" nolabel="1">
                                <list create="0" delete="0" edit="0">
                                    <field name="task_id"/>
                                    <field name="task_name"/>
                                    <field name="op_work_package_id"/>
                                    <field name="op_project_id"/>
                                    <field name="current_project_id"/>
                                    <field name="target_project_id"/>
                                    <field name="parent_action"/>
                                    <field name="stage_action"/>
                                    <field name="action"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                        <page string="Audit JSON" groups="base.group_no_one">
                            <field name="audit_json" nolabel="1" colspan="2"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
