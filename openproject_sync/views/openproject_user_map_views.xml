<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_openproject_user_map_list" model="ir.ui.view">
        <field name="name">openproject.user.map.list</field>
        <field name="model">openproject.user.map</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="backend_id"/>
                <field name="op_user_id"/>
                <field name="op_user_email"/>
                <field name="odoo_user_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_openproject_user_map" model="ir.actions.act_window">
        <field name="name">User Maps</field>
        <field name="res_model">openproject.user.map</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
