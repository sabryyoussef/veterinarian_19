<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">
    
    <!-- Vaccination Due Reminders - Daily at 9 AM -->
    <record id="cron_vaccination_reminders" model="ir.cron">
      <field name="name">Pet Vaccination Due Reminders</field>
      <field name="model_id" ref="model_pet_notification"/>
      <field name="state">code</field>
      <field name="code">model.create_vaccination_reminders()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active" eval="True"/>
      <field name="user_id" ref="base.user_root"/>
    </record>

    <!-- Overdue Vaccination Alerts - Daily at 10 AM -->
    <record id="cron_overdue_vaccinations" model="ir.cron">
      <field name="name">Pet Overdue Vaccination Alerts</field>
      <field name="model_id" ref="model_pet_notification"/>
      <field name="state">code</field>
      <field name="code">model.create_overdue_notifications()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active" eval="True"/>
      <field name="user_id" ref="base.user_root"/>
    </record>

    <!-- Appointment Reminders - Every 6 hours -->
    <record id="cron_appointment_reminders" model="ir.cron">
      <field name="name">Pet Appointment Reminders</field>
      <field name="model_id" ref="model_pet_notification"/>
      <field name="state">code</field>
      <field name="code">model.create_appointment_reminders()</field>
      <field name="interval_number">6</field>
      <field name="interval_type">hours</field>
      <field name="active" eval="True"/>
      <field name="user_id" ref="base.user_root"/>
    </record>

    <!-- Send Scheduled Notifications - Every 30 minutes -->
    <record id="cron_send_notifications" model="ir.cron">
      <field name="name">Send Scheduled Pet Notifications</field>
      <field name="model_id" ref="model_pet_notification"/>
      <field name="state">code</field>
      <field name="code">model.send_scheduled_notifications()</field>
      <field name="interval_number">30</field>
      <field name="interval_type">minutes</field>
      <field name="active" eval="True"/>
      <field name="user_id" ref="base.user_root"/>
    </record>

  </data>
</odoo>
