#: model:mail.template,body_html:pet_management.email_template_pet_notification
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dear ${object.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            ${object.message}\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-left: 4px solid #007bff; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #007bff;\">Pet Information</h3>\n"
"            <p style=\"margin: 0;\"><strong>Pet Name:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Species:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Breed:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Age:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #fff3cd; padding: 15px; border-left: 4px solid #ffc107; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_overdue'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #856404;\">⚠️ URGENT ACTION REQUIRED</h3>\n"
"            <p style=\"margin: 0; color: #856404;\">\n"
"              This is an urgent reminder. Please contact us immediately to schedule your pet's overdue vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-left: 4px solid #17a2b8; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_due'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">📅 Upcoming Vaccination</h3>\n"
"            <p style=\"margin: 0; color: #0c5460;\">\n"
"              Please schedule an appointment for your pet's upcoming vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d4edda; padding: 15px; border-left: 4px solid #28a745; margin: 20px 0;\" t-if=\"object.notification_type == 'appointment_reminder'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #155724;\">📞 Appointment Reminder</h3>\n"
"            <p style=\"margin: 0; color: #155724;\">\n"
"              Don't forget about your upcoming appointment.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            If you have any questions or need to reschedule, please contact us at your earliest convenience.\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Best regards,<br>\n"
"            Pet Management Team\n"
"          </p>\n"
"          <hr style=\"margin: 20px 0; border: none; border-top: 1px solid #dee2e6;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 11px; color: #6c757d;\">\n"
"            This is an automated notification. Please do not reply to this email.\n"
"          </p>\n"
"        </div>\n"
"      "
msgstr ""
"<div style = \"marge: 0px; opvulling: 0px; lettergrootte: 13px;\">\n"
"          <p style = \"marge: 0px; opvulling: 0px; font-grootte: 13px;\">\n"
"            Liewe __ph_0__,\n"
"          </p>\n"
"          <br>\n"
"          <p style = \"marge: 0px; opvulling: 0px; font-grootte: 13px;\">\n"
"            __Ph_1__\n"
"          </p>\n"
"          <br>\n"
"          <div style = \"agtergrondkleur: #f8f9fa; opvulling: 15px; grens-links: 4px soliede #007bff; marge: 20px 0;\">\n"
"            <h3 style = \"marge: 0 0 10px 0; kleur: #007bff;\"> troeteldierinligting </h3>\n"
"            <p style = \"marge: 0;\"> <strong> troeteldiernaam: </strong> __ph_2 __ </p>\n"
"            <p style = \"marge: 0;\"> <strong> spesie: </strong> __ph_3 __ </p>\n"
"            <p style = \"marge: 0;\"> <strong> ras: </strong> __ph_4 __ </p>\n"
"            <p style = \"marge: 0;\"> <strong> ouderdom: </strong> __ph_5 __ </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"agtergrondkleur: #fff3cd; opvulling: 15px; grens-links: 4px soliede #ffc107; marge: 20px 0;\" t-if = \"objek.notification_type == 'inenting_overdue'\">\n"
"            <h3 style = \"marge: 0 0 10px 0; kleur: #856404;\"> ⚠️ dringende aksie benodig </h3>\n"
"            <p styl = \"marge: 0; kleur: #856404;\">\n"
"              Dit is 'n dringende herinnering. Kontak ons ​​onmiddellik om die agterstallige inenting van u troeteldier te skeduleer.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"agtergrondkleur: #d1ecf1; opvulling: 15px; grens-links: 4px soliede #17a2b8; marge: 20px 0;\" t-if = \"objek.notification_type == 'inenting_due'\">\n"
"            <h3 style = \"marge: 0 0 10px 0; kleur: #0c5460;\"> 📅 komende inenting </h3>\n"
"            <p style = \"marge: 0; kleur: #0c5460;\">\n"
"              Beplan asseblief 'n afspraak vir die komende inenting van u troeteldier.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"agtergrondkleur: #d4edda; opvulling: 15px; grens-links: 4px soliede #28a745; marge: 20px 0;\" t-if = \"objek.notification_type == 'aanstelling_reminder'\">\n"
"            <h3 style = \"marge: 0 0 10px 0; kleur: #155724;\"> 📞 afspraakherinnering </h3>\n"
"            <p styl = \"marge: 0; kleur: #155724;\">\n"
"              Moenie van u komende afspraak vergeet nie.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <br>\n"
"          <p style = \"marge: 0px; opvulling: 0px; font-grootte: 13px;\">\n"
"            As u enige vrae het of moet herskeduleer, kontak ons ​​gerus so gou moontlik.\n"
"          </p>\n"
"          <br>\n"
"          <p style = \"marge: 0px; opvulling: 0px; font-grootte: 13px;\">\n"
"            Die beste groete, <br>\n"
"            Troeteldierbestuurspan\n"
"          </p>\n"
"          <hr style = \"marge: 20px 0; grens: geen; grens-top: 1px soliede #dee2e6;\">\n"
"          <p style = \"marge: 0px; opvulling: 0px; font-grootte: 11px; kleur: #6c757d;\">\n"
"            Dit is 'n outomatiese kennisgewing. Moet asseblief nie op hierdie e -pos antwoord nie.\n"
"          </p>\n"
"        </div>"

#. module: pet_management
#: model:mail.template,body_html:pet_management.email_template_vaccination_due
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dear ${object.pet_id.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #fff3cd; padding: 20px; border-left: 4px solid #ffc107; margin: 20px 0;\">\n"
"            <h2 style=\"margin: 0 0 15px 0; color: #856404;\">📅 Vaccination Due Reminder</h2>\n"
"            <p style=\"margin: 0 0 10px 0; font-size: 16px;\">\n"
"              <strong>${object.pet_id.name}</strong> is due for <strong>${object.vaccine_id.name}</strong> vaccination.\n"
"            </p>\n"
"            <p style=\"margin: 0; font-size: 14px; color: #856404;\">\n"
"              <strong>Due Date:</strong> ${object.next_due_date}<br>\n"
"              <strong>Days Until Due:</strong> ${object.days_since_vaccination} days\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #495057;\">Pet Information</h3>\n"
"            <p style=\"margin: 0;\"><strong>Pet Name:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Species:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Breed:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Age:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">Vaccination Details</h3>\n"
"            <p style=\"margin: 0;\"><strong>Vaccine:</strong> ${object.vaccine_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Type:</strong> ${object.vaccination_type}</p>\n"
"            <p style=\"margin: 0;\"><strong>Last Administered:</strong> ${object.date_administered}</p>\n"
"            <p style=\"margin: 0;\"><strong>Next Due:</strong> ${object.next_due_date}</p>\n"
"          </div>\n"
"          \n"
"          <p style=\"margin: 20px 0; padding: 15px; background-color: #e7f3ff; border-left: 4px solid #007bff; border-radius: 5px;\">\n"
"            <strong>Action Required:</strong> Please contact us to schedule your pet's vaccination appointment. \n"
"            Regular vaccinations are essential for your pet's health and well-being.\n"
"          </p>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Best regards,<br>\n"
"            Pet Management Team\n"
"          </p>\n"
"        </div>\n"
"      "
msgstr ""
"<div style = \"marge: 0px; opvulling: 0px; lettergrootte: 13px;\">\n"
"          <p style = \"marge: 0px; opvulling: 0px; font-grootte: 13px;\">\n"
"            Liewe __ph_0__,\n"
"          </p>\n"
"          <br>\n"
"          <div style = \"agtergrondkleur: #fff3cd; opvulling: 20px; grens-links: 4px soliede #ffc107; marge: 20px 0;\">\n"
"            <h2 style = \"marge: 0 0 15px 0; kleur: #856404;\"> 📅 inenting as gevolg van herinnering </h2>\n"
"            <p style = \"marge: 0 0 10px 0; font-grootte: 16px;\">\n"
"              <strong> __ Ph_1 __ </strong> is te danke aan <strong> __ pH_2 __ </strong> inenting.\n"
"            </p>\n"
"            <p style = \"marge: 0; font-grootte: 14px; kleur: #856404;\">\n"
"              <strong> vervaldatum: </strong> __ph_3__ <br>\n"
"              <strong> dae tot verskuldig: </strong> ${object.days_since_vaccination} dae\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"agtergrondkleur: #f8f9fa; opvulling: 15px; grensradius: 5px; marge: 20px 0;\">\n"
"            <h3 style = \"marge: 0 0 10px 0; kleur: #495057;\"> PET -inligting </h3>\n"
"            <p style = \"marge: 0;\"> <strong> troeteldiernaam: </strong> __ph_1 __ </p>\n"
"            <p style = \"marge: 0;\"> <strong> spesie: </strong> __ph_6 __ </p>\n"
"            <p style = \"marge: 0;\"> <strong> ras: </strong> __ph_7 __ </p>\n"
"            <p style = \"marge: 0;\"> <strong> ouderdom: </strong> __ph_8 __ </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"agtergrondkleur: #d1ecf1; opvulling: 15px; grensradius: 5px; marge: 20px 0;\">\n"
"            <h3 style = \"marge: 0 0 10px 0; kleur: #0c5460;\"> inentingsbesonderhede </h3>\n"
"            <p style = \"marge: 0;\"> <strong> entstof: </strong> __ph_2 __ </p>\n"
"            <p style = \"marge: 0;\"> <strong> tipe: </strong> __ph_10 __ </p>\n"
"            <p style = \"marge: 0;\"> <strong> laas toegedien: </strong> __ph_11 __ </p>\n"
"            <p style = \"marge: 0;\"> <strong> volgende te danke: </strong> __ph_3 __ </p>\n"
"          </div>\n"
"          \n"
"          <p style = \"marge: 20px 0; opvulling: 15px; agtergrondkleur: #e7f3ff; grens-links: 4px soliede #007bff; grensradius: 5px;\">\n"
"            <strong> Aksie benodig: </strong> Kontak ons ​​asseblief om die inenting van u troeteldier te skeduleer. \n"
"            Gereelde inentings is noodsaaklik vir die gesondheid en welstand van u troeteldier.\n"
"          </p>\n"
"          \n"
"          <br>\n"
"          <p style = \"marge: 0px; opvulling: 0px; font-grootte: 13px;\">\n"
"            Die beste groete, <br>\n"
"            Troeteldierbestuurspan\n"
"          </p>\n"
"        </div>"

