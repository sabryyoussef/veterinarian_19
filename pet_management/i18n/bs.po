#. module: pet_management
#: model:mail.template,body_html:pet_management.email_template_pet_notification
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dear ${object.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            ${object.message}\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-left: 4px solid #007bff; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #007bff;\">Pet Information</h3>\n"
"            <p style=\"margin: 0;\"><strong>Pet Name:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Species:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Breed:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Age:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #fff3cd; padding: 15px; border-left: 4px solid #ffc107; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_overdue'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #856404;\">⚠️ URGENT ACTION REQUIRED</h3>\n"
"            <p style=\"margin: 0; color: #856404;\">\n"
"              This is an urgent reminder. Please contact us immediately to schedule your pet's overdue vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-left: 4px solid #17a2b8; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_due'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">📅 Upcoming Vaccination</h3>\n"
"            <p style=\"margin: 0; color: #0c5460;\">\n"
"              Please schedule an appointment for your pet's upcoming vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d4edda; padding: 15px; border-left: 4px solid #28a745; margin: 20px 0;\" t-if=\"object.notification_type == 'appointment_reminder'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #155724;\">📞 Appointment Reminder</h3>\n"
"            <p style=\"margin: 0; color: #155724;\">\n"
"              Don't forget about your upcoming appointment.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            If you have any questions or need to reschedule, please contact us at your earliest convenience.\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Best regards,<br>\n"
"            Pet Management Team\n"
"          </p>\n"
"          <hr style=\"margin: 20px 0; border: none; border-top: 1px solid #dee2e6;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 11px; color: #6c757d;\">\n"
"            This is an automated notification. Please do not reply to this email.\n"
"          </p>\n"
"        </div>\n"
"      "
msgstr ""
"<div style = \"margina: 0px; obloga: 0px; veličina fonta: 13px;\">\n"
"<p style = \"margina: 0px; obloga: 0px; veličina fonta: 13px;\">\n"
"Dragi __Ph_0__,\n"
"</ p>\n"
"<br>\n"
"<p style = \"margina: 0px; obloga: 0px; veličina fonta: 13px;\">\n"
"__Ph_1__\n"
"</ p>\n"
"<br>\n"
"<div style = \"Boja pozadine: # f8f9fa; obloga: 15px; pogranično lijevo: 4px solid # 007bff; margina: 20px 0;\">\n"
"<h3 style = \"margina: 0 0 10px 0; boja: # 007bff;\"> informacije o kućnim ljubimcima </ h3>\n"
"<p Style = \"Marža: 0;\"> <strong> Naziv za kućne ljubimce: </ strong> __Ph_2 __ </ p>\n"
"<p style = \"margina: 0;\"> <strong> vrste: </ strong> __Ph_3 __ </ p>\n"
"<p Style = \"Margin: 0;\"> <strong> pasmina: </ strong> __Ph_4 __ </ p>\n"
"<p Style = \"Marža: 0;\"> <strong> Starost: </ strong> __Ph_5 __ </ p>\n"
"</ div>\n"
"\n"
"<div style = \"Boja pozadine: # fff3cd; obloga: 15px; pogranično lijevo: 4px solid # ffc107; margina: 20px 0;\"t-if = \"objekt.notification_type == 'vaccinacija_overdue'\">\n"
"<h3 stil = \"Marža: 0 0 10px 0; boja: # 856404;\"> ⚠️ Potrebna je hitna akcija </ h3>\n"
"<p style = \"margina: 0; boja: # 856404;\">\n"
"Ovo je hitan podsjetnik.Molimo kontaktirajte nas odmah da zakažemo dospjele vakcinaciju vašeg kućnog ljubimca.\n"
"</ p>\n"
"</ div>\n"
"\n"
"<div style = \"Boja pozadine: # D1ECF1; obloga: 15px; pogranično lijevo: 4px solid # 17A2B8; margina: 20px 0;\"t-if = \"objekt.notification_type == 'vakcinacija_due'\">\n"
"<h3 stil = \"Marža: 0 0 10px 0; boja: # 0c5460;\"> 📅 nadolazeća vakcinacija </ h3>\n"
"<p style = \"margina: 0; boja: # 0c5460;\">\n"
"Zakažite sastanak za nadolazeću vakcinaciju vašeg ljubimca.\n"
"</ p>\n"
"</ div>\n"
"\n"
"<div style = \"Boja pozadine: # D4EDDA; obloga: 15px; pogranično lijevo: 4px solid # 28A745; margina: 20px 0;\"t-if = \"objekt.Notifikacija_type == 'termin_reminder'\">\n"
"<h3 style = \"margina: 0 0 10px 0; boja: # 155724;\"> 📞 podsjetnik za imenovanje </ h3>\n"
"<p style = \"margina: 0; boja: # 155724;\">\n"
"Ne zaboravite na svoj nadolazeći sastanak.\n"
"</ p>\n"
"</ div>\n"
"\n"
"<br>\n"
"<p style = \"margina: 0px; obloga: 0px; veličina fonta: 13px;\">\n"
"Ako imate bilo kakvih pitanja ili potrebe za odgodom, obratite nam se u najranijoj praktičnosti.\n"
"</ p>\n"
"<br>\n"
"<p style = \"margina: 0px; obloga: 0px; veličina fonta: 13px;\">\n"
"Srdačan pozdrav, <br>\n"
"Tim za upravljanje kućnim ljubimcima\n"
"</ p>\n"
"<hr Style = \"Marža: 20px 0; granica: nema; granični top: 1px solid # dee2e6;\">\n"
"<p style = \"margina: 0px; obloga: 0px; veličina fonta: 11px; boja: # 6c757d;\">\n"
"Ovo je automatizirana obavijest.Molimo ne odgovarajte na ovu e-poštu.\n"
"</ p>\n"
"</ div>"

#. module: pet_management
#: model:mail.template,body_html:pet_management.email_template_vaccination_due
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dear ${object.pet_id.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #fff3cd; padding: 20px; border-left: 4px solid #ffc107; margin: 20px 0;\">\n"
"            <h2 style=\"margin: 0 0 15px 0; color: #856404;\">📅 Vaccination Due Reminder</h2>\n"
"            <p style=\"margin: 0 0 10px 0; font-size: 16px;\">\n"
"              <strong>${object.pet_id.name}</strong> is due for <strong>${object.vaccine_id.name}</strong> vaccination.\n"
"            </p>\n"
"            <p style=\"margin: 0; font-size: 14px; color: #856404;\">\n"
"              <strong>Due Date:</strong> ${object.next_due_date}<br>\n"
"              <strong>Days Until Due:</strong> ${object.days_since_vaccination} days\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #495057;\">Pet Information</h3>\n"
"            <p style=\"margin: 0;\"><strong>Pet Name:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Species:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Breed:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Age:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">Vaccination Details</h3>\n"
"            <p style=\"margin: 0;\"><strong>Vaccine:</strong> ${object.vaccine_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Type:</strong> ${object.vaccination_type}</p>\n"
"            <p style=\"margin: 0;\"><strong>Last Administered:</strong> ${object.date_administered}</p>\n"
"            <p style=\"margin: 0;\"><strong>Next Due:</strong> ${object.next_due_date}</p>\n"
"          </div>\n"
"          \n"
"          <p style=\"margin: 20px 0; padding: 15px; background-color: #e7f3ff; border-left: 4px solid #007bff; border-radius: 5px;\">\n"
"            <strong>Action Required:</strong> Please contact us to schedule your pet's vaccination appointment. \n"
"            Regular vaccinations are essential for your pet's health and well-being.\n"
"          </p>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Best regards,<br>\n"
"            Pet Management Team\n"
"          </p>\n"
"        </div>\n"
"      "
msgstr ""
"<div style = \"margina: 0px; obloga: 0px; veličina fonta: 13px;\">\n"
"<p style = \"margina: 0px; obloga: 0px; veličina fonta: 13px;\">\n"
"Dragi __Ph_0__,\n"
"</ p>\n"
"<br>\n"
"<div style = \"Boja pozadine: # fff3cd; obloga: 20px; pogranično lijevo: 4px solid # ffc107; margina: 20px 0;\">\n"
"<h2 style = \"margina: 0 0 15px 0; boja: # 856404;\"> 📅 vakcinacija podnosi podsjetnik </ h2>\n"
"<p style = \"margina: 0 0 10px 0; veličina fonta: 16px;\">\n"
"<Strong> __ ph_1 __ </ strong> dospijeva za <strong> __ ph_2 __ </ strong> vakcinaciju.\n"
"</ p>\n"
"<p style = \"margina: 0; veličina fonta: 14px; boja: # 856404;\">\n"
"<strong> Datum dospijeća: </ strong> __Ph_3__ <br>\n"
"<Strong> Dani do dele: </ strong> __Ph_4__ dana\n"
"</ p>\n"
"</ div>\n"
"\n"
"<div style = \"Boja pozadine: # f8f9fa; obloga: 15px; granični radijus: 5px; margina: 20px 0;\">\n"
"<h3 style = \"Marža: 0 0 10px 0; boja: # 495057;\"> Informacije o kućnim ljubimcima </ h3>\n"
"<p Style = \"Marža: 0;\"> <strong> Naziv za kućne ljubimce: </ strong> __Ph_1 __ </ p>\n"
"<p style = \"margina: 0;\"> <strong> vrste: </ strong> __Ph_6 __ </ p>\n"
"<p Style = \"Marža: 0;\"> <strong> pasmina: </ strong> __Ph_7 __ </ p>\n"
"<p Style = \"Marža: 0;\"> <strong> Starost: </ strong> __Ph_8 __ </ p>\n"
"</ div>\n"
"\n"
"<div style = \"Boja pozadine: # d1ecf1; obloga: 15px; granični radijus: 5px; margina: 20px 0;\">\n"
"<h3 style = \"margina: 0 0 10px 0; boja: # 0c5460;\"> Detalji vakcinacije </ h3>\n"
"<p Style = \"Marža: 0;\"> <strong> vakcina: </ strong> __Ph_2 __ </ p>\n"
"<p Style = \"Marža: 0;\"> <strong> Tip: </ strong> __Ph_10 __ </ p>\n"
"<p Style = \"Marža: 0;\"> <strong> zadnja primjena: </ strong> __Ph_11 __ </ p>\n"
"<p Style = \"Marža: 0;\"> <strong> Sljedeći Dospio: </ strong> __Ph_3 __ </ p>\n"
"</ div>\n"
"\n"
"<p Style = \"Margin: 20px 0; obloga: 15px; boja pozadine: # E7F3FF; Ground-lijevo: 4px solid # 007bff; granični radijus: 5px;\">\n"
"<Strong> Potrebna radnja: </ strong> Molimo kontaktirajte nas kako bismo zakazali sastanak vakcinacije vašeg ljubimca.\n"
"Redovna vakcinacija su od suštinske važnosti za zdravlje i blagostanje vašeg ljubimca.\n"
"</ p>\n"
"\n"
"<br>\n"
"<p style = \"margina: 0px; obloga: 0px; veličina fonta: 13px;\">\n"
"Srdačan pozdrav, <br>\n"
"Tim za upravljanje kućnim ljubimcima\n"
"</ p>\n"
"</ div>"

