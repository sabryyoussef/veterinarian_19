"            <p style=\"margin: 0;\"><strong>Vaccine:</strong> ${object.vaccine_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Type:</strong> ${object.vaccination_type}</p>\n"
"            <p style=\"margin: 0;\"><strong>Last Administered:</strong> ${object.date_administered}</p>\n"
"            <p style=\"margin: 0;\"><strong>Next Due:</strong> ${object.next_due_date}</p>\n"
"          </div>\n"
"          \n"
"          <p style=\"margin: 20px 0; padding: 15px; background-color: #e7f3ff; border-left: 4px solid #007bff; border-radius: 5px;\">\n"
"            <strong>Action Required:</strong> Please contact us to schedule your pet's vaccination appointment. \n"
"            Regular vaccinations are essential for your pet's health and well-being.\n"
"          </p>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Best regards,<br>\n"
"            Pet Management Team\n"
"          </p>\n"
"        </div>\n"
"      "
msgstr ""
"<div style = \"margin: 0px; padding: 0px; písmo-velikost: 13px;\">\n"
"          <p style = \"margin: 0px; padding: 0px; písmo-velikost: 13px;\">\n"
"            Drahý __ph_0__,\n"
"          </p>\n"
"          <br>\n"
"          <div style = \"pozadí-color: #fff3cd; padding: 20px; border-left: 4px solid #ffc107; marže: 20px 0;\">\n"
"            <h2 style = \"margin: 0 0 15px 0; barva: #856404;\"> 📅 Vakcinace splatná připomenutí </h2>\n"
"            <p style = \"margin: 0 0 10px 0; velikost font: 16px;\">\n"
"              <strong> __ ph_1 __ </strong> je způsoben <strong> __ ph_2 __ </strong> očkováním.\n"
"            </p>\n"
"            <p style = \"margin: 0; font-size: 14px; barva: #856404;\">\n"
"              <strong> datum splatnosti: </strong> __ph_3__ <br>\n"
"              <strong> dny do splatnosti: </strong> __ph_4__ dny\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"pozadí-color: #f8f9fa; padding: 15px; border-radius: 5px; marže: 20px 0;\">\n"
"            <h3 style = \"margin: 0 0 10px 0; barva: #495057;\"> Informace o domácím mazlíčku </h3>\n"
"            <p style = \"margin: 0;\"> <strong> název domácího mazlíčka: </strong> __ph_1 __ </p>\n"
"            <p style = \"margin: 0;\"> <strong> druh: </strong> __ph_6 __ </p>\n"
"            <p style = \"margin: 0;\"> <strong> plemeno: </strong> __ph_7 __ </p>\n"
"            <p style = \"margin: 0;\"> <strong> věk: </strong> __ph_8 __ </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"pozadí-color: #d1ecf1; padding: 15px; border-radius: 5px; marže: 20px 0;\">\n"
"            <h3 style = \"margin: 0 0 10px 0; barva: #0c5460;\"> očkovací detaily </h3>\n"
"            <p style = \"margin: 0;\"> <strong> vakcína: </strong> __ph_2 __ </p>\n"
"            <p style = \"margin: 0;\"> <strong> typ: </strong> __ph_10 __ </p>\n"
"            <p style = \"margin: 0;\"> <strong> naposledy spravováno: </strong> __ph_11 __ </p>\n"
"            <p style = \"margin: 0;\"> <strong> Další splatný: </strong> __ph_3 __ </p>\n"
"          </div>\n"
"          \n"
"          <p style = \"margin: 20px 0; polstrování: 15px; pozadí-color: #e7f3ff; border-left: 4px solid #007bff; border-radius: 5px;\">\n"
"            <strong> Požadovaná akce: </strong> Kontaktujte nás a naplánujte si očkovací jmenování vašeho domácího mazlíčka. \n"
"            Pravidelné očkování jsou nezbytné pro zdraví a pohodu vašeho domácího mazlíčka.\n"
"          </p>\n"
"          \n"
"          <br>\n"
"          <p style = \"margin: 0px; padding: 0px; písmo-velikost: 13px;\">\n"
"            S pozdravem, <br>\n"
"            Tým pro správu domácích zvířat\n"
"          </p>\n"
"        </div>"

