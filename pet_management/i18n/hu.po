"            <p style = \"margin: 0;\"> <strong> utoljára beadva: </strong> __ph_11 __ </p>\n"
"            <p style = \"margin: 0;\"> <strong> Következő esedékes: </strong> __ph_3 __ </p>\n"
"          </div>\n"
"          \n"
"          <p style = \"margin: 20px 0; padding: 15 px; háttér szín: #e7f3ff; Border-bal: 4px Solid #007bff; Border-Radius: 5px;\">\n"
