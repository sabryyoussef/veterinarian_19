"          \n"
"          <div style = \"háttér-szín: #f8f9fa; padding: 15 px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style = \"margin: 0 0 10 px 0; szín: #495057;\"> PET információk </h3>\n"
"            <p style = \"margin: 0;\"> <strong> PET név: </strong> __ph_1 __ </p>\n"
"            <p style = \"margin: 0;\"> <strong> fajok: </strong> __ph_6 __ </p>\n"
"            <p style = \"margin: 0;\"> <strong> fajta: </strong> __ph_7 __ </p>\n"
"            <p style = \"margin: 0;\"> <strong> életkor: </strong> __ph_8 __ </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"háttér-szín: #d1ecf1; padding: 15 px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style = \"margin: 0 0 10 px 0; szín: #0C5460;\"> Vakcinációs részletek </h3>\n"
"            <p style = \"margin: 0;\"> <strong> oltás: </strong> __ph_2 __ </p>\n"
