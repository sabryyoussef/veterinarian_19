#. module: pet_management
#: model:mail.template,body_html:pet_management.email_template_pet_notification
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dear ${object.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            ${object.message}\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-left: 4px solid #007bff; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #007bff;\">Pet Information</h3>\n"
"            <p style=\"margin: 0;\"><strong>Pet Name:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Species:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Breed:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Age:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #fff3cd; padding: 15px; border-left: 4px solid #ffc107; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_overdue'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #856404;\">⚠️ URGENT ACTION REQUIRED</h3>\n"
"            <p style=\"margin: 0; color: #856404;\">\n"
"              This is an urgent reminder. Please contact us immediately to schedule your pet's overdue vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-left: 4px solid #17a2b8; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_due'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">📅 Upcoming Vaccination</h3>\n"
"            <p style=\"margin: 0; color: #0c5460;\">\n"
"              Please schedule an appointment for your pet's upcoming vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d4edda; padding: 15px; border-left: 4px solid #28a745; margin: 20px 0;\" t-if=\"object.notification_type == 'appointment_reminder'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #155724;\">📞 Appointment Reminder</h3>\n"
"            <p style=\"margin: 0; color: #155724;\">\n"
"              Don't forget about your upcoming appointment.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            If you have any questions or need to reschedule, please contact us at your earliest convenience.\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Best regards,<br>\n"
"            Pet Management Team\n"
"          </p>\n"
"          <hr style=\"margin: 20px 0; border: none; border-top: 1px solid #dee2e6;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 11px; color: #6c757d;\">\n"
"            This is an automated notification. Please do not reply to this email.\n"
"          </p>\n"
"        </div>\n"
"      "
msgstr ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            ${object.owner_id.name or 'Pet Owner'}様、\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            ${object.message}\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-left: 4px solid #007bff; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #007bff;\">ペット情報</h3>\n"
"            <p style=\"margin: 0;\"><strong>ペット名:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>種:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>品種:</strong> ${object.pet_id.breed_id.name or 'ミックス'}</p>\n"
"            <p style=\"margin: 0;\"><strong>年齢:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #fff3cd; padding: 15px; border-left: 4px solid #ffc107; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_overdue'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #856404;\">⚠️ 緊急対応が必要</h3>\n"
"            <p style=\"margin: 0; color: #856404;\">\n"
"              これは緊急のリマインダーです。ペットの期限切れワクチン接種の予約を今すぐご連絡ください。\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-left: 4px solid #17a2b8; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_due'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">📅 今後のワクチン接種</h3>\n"
"            <p style=\"margin: 0; color: #0c5460;\">\n"
"              ペットの今後のワクチン接種の予約をしてください。\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d4edda; padding: 15px; border-left: 4px solid #28a745; margin: 20px 0;\" t-if=\"object.notification_type == 'appointment_reminder'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #155724;\">📞 予約リマインダー</h3>\n"
"            <p style=\"margin: 0; color: #155724;\">\n"
"              今後の予約をお忘れなく。\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            ご質問や予約の変更が必要な場合は、お早めにご連絡ください。\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            よろしくお願いいたします。<br>\n"
"            ペット管理チーム\n"
"          </p>\n"
"          <hr style=\"margin: 20px 0; border: none; border-top: 1px solid #dee2e6;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 11px; color: #6c757d;\">\n"
"            これは自動通知です。このメールに返信しないでください。\n"
"          </p>\n"
"        </div>\n"
"      "

#. module: pet_management
#: model:mail.template,body_html:pet_management.email_template_vaccination_due
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dear ${object.pet_id.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #fff3cd; padding: 20px; border-left: 4px solid #ffc107; margin: 20px 0;\">\n"
"            <h2 style=\"margin: 0 0 15px 0; color: #856404;\">📅 Vaccination Due Reminder</h2>\n"
"            <p style=\"margin: 0 0 10px 0; font-size: 16px;\">\n"
"              <strong>${object.pet_id.name}</strong> is due for <strong>${object.vaccine_id.name}</strong> vaccination.\n"
"            </p>\n"
"            <p style=\"margin: 0; font-size: 14px; color: #856404;\">\n"
"              <strong>Due Date:</strong> ${object.next_due_date}<br>\n"
"              <strong>Days Until Due:</strong> ${object.days_since_vaccination} days\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #495057;\">Pet Information</h3>\n"
"            <p style=\"margin: 0;\"><strong>Pet Name:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Species:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Breed:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Age:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">Vaccination Details</h3>\n"
"            <p style=\"margin: 0;\"><strong>Vaccine:</strong> ${object.vaccine_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Type:</strong> ${object.vaccination_type}</p>\n"
"            <p style=\"margin: 0;\"><strong>Last Administered:</strong> ${object.date_administered}</p>\n"
"            <p style=\"margin: 0;\"><strong>Next Due:</strong> ${object.next_due_date}</p>\n"
"          </div>\n"
"          \n"
"          <p style=\"margin: 20px 0; padding: 15px; background-color: #e7f3ff; border-left: 4px solid #007bff; border-radius: 5px;\">\n"
"            <strong>Action Required:</strong> Please contact us to schedule your pet's vaccination appointment. \n"
"            Regular vaccinations are essential for your pet's health and well-being.\n"
"          </p>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Best regards,<br>\n"
"            Pet Management Team\n"
"          </p>\n"
"        </div>\n"
"      "
msgstr ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            ${object.pet_id.owner_id.name or 'Pet Owner'}様、\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #fff3cd; padding: 20px; border-left: 4px solid #ffc107; margin: 20px 0;\">\n"
"            <h2 style=\"margin: 0 0 15px 0; color: #856404;\">📅 ワクチン接種期限リマインダー</h2>\n"
"            <p style=\"margin: 0 0 10px 0; font-size: 16px;\">\n"
"              <strong>${object.pet_id.name}</strong>は<strong>${object.vaccine_id.name}</strong>ワクチンの接種期限です。\n"
"            </p>\n"
"            <p style=\"margin: 0; font-size: 14px; color: #856404;\">\n"
"              <strong>期限日:</strong> ${object.next_due_date}<br>\n"
"              <strong>期限まで:</strong> ${object.days_since_vaccination}日\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #495057;\">ペット情報</h3>\n"
"            <p style=\"margin: 0;\"><strong>ペット名:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>種:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>品種:</strong> ${object.pet_id.breed_id.name or 'ミックス'}</p>\n"
"            <p style=\"margin: 0;\"><strong>年齢:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">ワクチン詳細</h3>\n"
"            <p style=\"margin: 0;\"><strong>ワクチン:</strong> ${object.vaccine_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>種類:</strong> ${object.vaccination_type}</p>\n"
"            <p style=\"margin: 0;\"><strong>最終投与日:</strong> ${object.date_administered}</p>\n"
"            <p style=\"margin: 0;\"><strong>次回期限:</strong> ${object.next_due_date}</p>\n"
"          </div>\n"
"          \n"
"          <p style=\"margin: 20px 0; padding: 15px; background-color: #e7f3ff; border-left: 4px solid #007bff; border-radius: 5px;\">\n"
"            <strong>必要なアクション:</strong> ペットのワクチン接種予約のため、ご連絡ください。\n"
"            定期的なワクチン接種は、ペットの健康と幸福のために重要です。\n"
"          </p>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            よろしくお願いいたします。<br>\n"
"            ペット管理チーム\n"
"          </p>\n"
"        </div>\n"
"      "

