"            Beste __ph_0__,\n"
"          </p>\n"
"          <br>\n"
"          <p style = \"marge: 0px; padding: 0px; font-size: 13px;\">\n"
"            __Ph_1__\n"
"          </p>\n"
"          <br>\n"
"          <div style = \"Background-Color: #f8f9fa; padding: 15px; border-left: 4px solid #007bff; marge: 20px 0;\">\n"
"            <h3 style = \"marge: 0 0 10px 0; kleur: #007bff;\"> PET -informatie </h3>\n"
"            <p style = \"marge: 0;\"> <strong> PET Naam: </strong> __ph_2 __ </p>\n"
"            <p style = \"marge: 0;\"> <strong> soorten: </strong> __ph_3 __ </p>\n"
"            <p style = \"marge: 0;\"> <strong> ras: </strong> __ph_4 __ </p>\n"
"            <p style = \"marge: 0;\"> <strong> leeftijd: </strong> __ph_5 __ </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"Background-Color: #fff3cd; padding: 15px; border-left: 4px solid #ffc107; marge: 20px 0;\" t-if = \"object.notification_type == 'vaccination_overdue'\">\n"
"            <h3 style = \"margin: 0 0 10px 0; kleur: #856404;\"> ⚠️ Dringende actie vereist </h3>\n"
"            <p style = \"marge: 0; kleur: #856404;\">\n"
"              Dit is een dringende herinnering. Neem onmiddellijk contact met ons op om de achterstallige vaccinatie van uw huisdier te plannen.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"Background-Color: #d1ecf1; padding: 15px; border-left: 4px solid #17a2b8; marge: 20px 0;\" t-if = \"object.notification_type == 'vaccination_due'\">\n"
"            <h3 style = \"marge: 0 0 10px 0; kleur: #0c5460;\"> 📅 aankomende vaccinatie </h3>\n"
"            <p style = \"marge: 0; kleur: #0c5460;\">\n"
"              Plan een afspraak voor de komende vaccinatie van uw huisdier.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"Background-Color: #d4edda; padding: 15px; border-left: 4px solid #28a745; marge: 20px 0;\" t-if = \"object.notification_type == 'afspraak_reminder'\">\n"
"            <h3 style = \"marge: 0 0 10px 0; kleur: #155724;\"> 📞 ApproS -herinnering </h3>\n"
"            <p style = \"marge: 0; kleur: #155724;\">\n"
"              Vergeet uw aankomende afspraak niet.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <br>\n"
"          <p style = \"marge: 0px; padding: 0px; font-size: 13px;\">\n"
"            Als u vragen hebt of opnieuw moet worden gepland, neem dan u zo snel mogelijk contact met ons op.\n"
"          </p>\n"
"          <br>\n"
"          <p style = \"marge: 0px; padding: 0px; font-size: 13px;\">\n"
"            Met vriendelijke groet, <br>\n"
"            Pet Management Team\n"
"          </p>\n"
"          <hr style = \"marge: 20px 0; border: geen; border-top: 1px solid #dee2e6;\">\n"
"          <p style = \"marge: 0px; padding: 0px; font-size: 11px; kleur: #6c757d;\">\n"
"            Dit is een geautomatiseerde melding. Beantwoord deze e -mail niet.\n"
"          </p>\n"
"        </div>"

#. module: pet_management
#: model:mail.template,body_html:pet_management.email_template_vaccination_due
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dear ${object.pet_id.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #fff3cd; padding: 20px; border-left: 4px solid #ffc107; margin: 20px 0;\">\n"
"            <h2 style=\"margin: 0 0 15px 0; color: #856404;\">📅 Vaccination Due Reminder</h2>\n"
"            <p style=\"margin: 0 0 10px 0; font-size: 16px;\">\n"
"              <strong>${object.pet_id.name}</strong> is due for <strong>${object.vaccine_id.name}</strong> vaccination.\n"
"            </p>\n"
"            <p style=\"margin: 0; font-size: 14px; color: #856404;\">\n"
"              <strong>Due Date:</strong> ${object.next_due_date}<br>\n"
"              <strong>Days Until Due:</strong> ${object.days_since_vaccination} days\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #495057;\">Pet Information</h3>\n"
"            <p style=\"margin: 0;\"><strong>Pet Name:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Species:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Breed:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Age:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">Vaccination Details</h3>\n"
"            <p style=\"margin: 0;\"><strong>Vaccine:</strong> ${object.vaccine_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Type:</strong> ${object.vaccination_type}</p>\n"
"            <p style=\"margin: 0;\"><strong>Last Administered:</strong> ${object.date_administered}</p>\n"
"            <p style=\"margin: 0;\"><strong>Next Due:</strong> ${object.next_due_date}</p>\n"
"          </div>\n"
"          \n"
"          <p style=\"margin: 20px 0; padding: 15px; background-color: #e7f3ff; border-left: 4px solid #007bff; border-radius: 5px;\">\n"
"            <strong>Action Required:</strong> Please contact us to schedule your pet's vaccination appointment. \n"
"            Regular vaccinations are essential for your pet's health and well-being.\n"
"          </p>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Best regards,<br>\n"
"            Pet Management Team\n"
"          </p>\n"
"        </div>\n"
"      "
msgstr ""
"<div style=\"marge: 0px; opvulling: 0px; lettergrootte: 13px;\">\n"
"          <p style=\"marge: 0px; opvulling: 0px; lettergrootte: 13px;\">\n"
"            Beste ${object.pet_id.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"achtergrondkleur: #fff3cd; opvulling: 20px; rand links: 4px effen #ffc107; marge: 20px 0;\">\n"
"            <h2 style=\"margin: 0 0 15px 0; color: #856404;\">📅 Herinnering voor vaccinatiedatum</h2>\n"
"            <p style=\"marge: 0 0 10px 0; lettergrootte: 16px;\">\n"
"              <strong>${object.pet_id.name}</strong> moet worden gevaccineerd tegen <strong>${object.vaccine_id.name}</strong>.\n"
"            </p>\n"
"            <p style=\"marge: 0; lettergrootte: 14px; kleur: #856404;\">\n"
"              <strong>Vervaldatum:</strong> ${object.next_due_date}<br>\n"
"              <strong>Dagen tot vervaldatum:</strong> ${object.days_since_vaccination} dagen\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"achtergrondkleur: #f8f9fa; opvulling: 15px; randradius: 5px; marge: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #495057;\">Huisdierinformatie</h3>\n"
"            <p style=\"margin: 0;\"><strong>Naam huisdier:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"marge: 0;\"><strong>Soort:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Rassen:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Leeftijd:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"achtergrondkleur: #d1ecf1; opvulling: 15px; randradius: 5px; marge: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">Vaccinatiedetails</h3>\n"
"            <p style=\"margin: 0;\"><strong>Vaccin:</strong> ${object.vaccine_id.name}</p>\n"
"            <p style=\"marge: 0;\"><strong>Type:</strong> ${object.vaccination_type}</p>\n"
"            <p style=\"margin: 0;\"><strong>Laatst beheerd:</strong> ${object.date_administered}</p>\n"
"            <p style=\"margin: 0;\"><strong>Volgende deadline:</strong> ${object.next_due_date}</p>\n"
"          </div>\n"
"          \n"
"          <p style=\"marge: 20px 0; opvulling: 15px; achtergrondkleur: #e7f3ff; rand-links: 4px effen #007bff; rand-radius: 5px;\">\n"
"            <strong>Actie vereist:</strong> Neem contact met ons op om de vaccinatieafspraak voor uw huisdier te plannen. \n"
"            Regelmatige vaccinaties zijn essentieel voor de gezondheid en het welzijn van uw huisdier.\n"
"          </p>\n"
"          \n"
"          <br>\n"
"          <p style=\"marge: 0px; opvulling: 0px; lettergrootte: 13px;\">\n"
"            Met vriendelijke groet,<br>\n"
"            Het huisdiermanagementteam\n"
"          </p>\n"
"        </div>"

