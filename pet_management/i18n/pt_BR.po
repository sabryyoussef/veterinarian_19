#. module: pet_management
#: model:mail.template,body_html:pet_management.email_template_pet_notification
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dear ${object.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            ${object.message}\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-left: 4px solid #007bff; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #007bff;\">Pet Information</h3>\n"
"            <p style=\"margin: 0;\"><strong>Pet Name:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Species:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Breed:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Age:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #fff3cd; padding: 15px; border-left: 4px solid #ffc107; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_overdue'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #856404;\">⚠️ URGENT ACTION REQUIRED</h3>\n"
"            <p style=\"margin: 0; color: #856404;\">\n"
"              This is an urgent reminder. Please contact us immediately to schedule your pet's overdue vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-left: 4px solid #17a2b8; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_due'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">📅 Upcoming Vaccination</h3>\n"
"            <p style=\"margin: 0; color: #0c5460;\">\n"
"              Please schedule an appointment for your pet's upcoming vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d4edda; padding: 15px; border-left: 4px solid #28a745; margin: 20px 0;\" t-if=\"object.notification_type == 'appointment_reminder'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #155724;\">📞 Appointment Reminder</h3>\n"
"            <p style=\"margin: 0; color: #155724;\">\n"
"              Don't forget about your upcoming appointment.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            If you have any questions or need to reschedule, please contact us at your earliest convenience.\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Best regards,<br>\n"
"            Pet Management Team\n"
"          </p>\n"
"          <hr style=\"margin: 20px 0; border: none; border-top: 1px solid #dee2e6;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 11px; color: #6c757d;\">\n"
"            This is an automated notification. Please do not reply to this email.\n"
"          </p>\n"
"        </div>\n"
"      "
msgstr ""
"<div style=\"margem: 0px; preenchimento: 0px; tamanho da fonte: 13px;\">\n"
"          <p style=\"margem: 0px; preenchimento: 0px; tamanho da fonte: 13px;\">\n"
"            Prezado ${object.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margem: 0px; preenchimento: 0px; tamanho da fonte: 13px;\">\n"
"            ${object.message}\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #f8f9fa; preenchimento: 15px; borda esquerda: 4px sólido #007bff; margem: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #007bff;\">Informações sobre animais de estimação</h3>\n"
"            <p style=\"margin: 0;\"><strong>Nome do animal de estimação:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Espécie:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Raça:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Idade:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"cor de fundo: #fff3cd; preenchimento: 15px; borda esquerda: 4px sólido #ffc107; margem: 20px 0;\" t-if=\"object.notification_type == 'vacinação_atrasada'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #856404;\">⚠️ AÇÃO URGENTE NECESSÁRIA</h3>\n"
"            <p style=\"margem: 0; cor: #856404;\">\n"
"              Este é um lembrete urgente. Entre em contato conosco imediatamente para agendar a vacinação em atraso do seu animal de estimação.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"cor de fundo: #d1ecf1; preenchimento: 15px; borda esquerda: 4px sólido #17a2b8; margem: 20px 0;\" t-if=\"object.notification_type == 'vacinação_devida'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">📅 Próxima vacinação</h3>\n"
"            <p style=\"margem: 0; cor: #0c5460;\">\n"
"              Agende uma consulta para a próxima vacinação do seu animal de estimação.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"cor de fundo: #d4edda; preenchimento: 15px; borda esquerda: 4px sólido #28a745; margem: 20px 0;\" t-if=\"object.notification_type == 'appointment_reminder'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #155724;\">📞 Lembrete de compromisso</h3>\n"
"            <p style=\"margem: 0; cor: #155724;\">\n"
"              Não se esqueça do seu próximo compromisso.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <br>\n"
"          <p style=\"margem: 0px; preenchimento: 0px; tamanho da fonte: 13px;\">\n"
"            Caso tenha alguma dúvida ou precise reagendar, entre em contato conosco o mais breve possível.\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margem: 0px; preenchimento: 0px; tamanho da fonte: 13px;\">\n"
"            Atenciosamente,<br>\n"
"            Equipe de gerenciamento de animais de estimação\n"
"          </p>\n"
"          <hr style=\"margem: 20px 0; borda: nenhuma; borda superior: 1px sólido #dee2e6;\">\n"
"          <p style=\"margem: 0px; preenchimento: 0px; tamanho da fonte: 11px; cor: #6c757d;\">\n"
"            Esta é uma notificação automática. Por favor, não responda a este e-mail.\n"
"          </p>\n"
"        </div>"

#. module: pet_management
#: model:mail.template,body_html:pet_management.email_template_vaccination_due
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dear ${object.pet_id.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #fff3cd; padding: 20px; border-left: 4px solid #ffc107; margin: 20px 0;\">\n"
"            <h2 style=\"margin: 0 0 15px 0; color: #856404;\">📅 Vaccination Due Reminder</h2>\n"
"            <p style=\"margin: 0 0 10px 0; font-size: 16px;\">\n"
"              <strong>${object.pet_id.name}</strong> is due for <strong>${object.vaccine_id.name}</strong> vaccination.\n"
"            </p>\n"
"            <p style=\"margin: 0; font-size: 14px; color: #856404;\">\n"
"              <strong>Due Date:</strong> ${object.next_due_date}<br>\n"
"              <strong>Days Until Due:</strong> ${object.days_since_vaccination} days\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #495057;\">Pet Information</h3>\n"
"            <p style=\"margin: 0;\"><strong>Pet Name:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Species:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Breed:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Age:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">Vaccination Details</h3>\n"
"            <p style=\"margin: 0;\"><strong>Vaccine:</strong> ${object.vaccine_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Type:</strong> ${object.vaccination_type}</p>\n"
"            <p style=\"margin: 0;\"><strong>Last Administered:</strong> ${object.date_administered}</p>\n"
"            <p style=\"margin: 0;\"><strong>Next Due:</strong> ${object.next_due_date}</p>\n"
"          </div>\n"
"          \n"
"          <p style=\"margin: 20px 0; padding: 15px; background-color: #e7f3ff; border-left: 4px solid #007bff; border-radius: 5px;\">\n"
"            <strong>Action Required:</strong> Please contact us to schedule your pet's vaccination appointment. \n"
"            Regular vaccinations are essential for your pet's health and well-being.\n"
"          </p>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Best regards,<br>\n"
"            Pet Management Team\n"
"          </p>\n"
"        </div>\n"
"      "
msgstr ""
"<div style=\"margem: 0px; preenchimento: 0px; tamanho da fonte: 13px;\">\n"
"          <p style=\"margem: 0px; preenchimento: 0px; tamanho da fonte: 13px;\">\n"
"            Prezado ${object.pet_id.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"cor de fundo: #fff3cd; preenchimento: 20px; borda esquerda: 4px sólido #ffc107; margem: 20px 0;\">\n"
"            <h2 style=\"margin: 0 0 15px 0; color: #856404;\">📅 Lembrete de vencimento de vacinação</h2>\n"
"            <p style=\"margem: 0 0 10px 0; tamanho da fonte: 16px;\">\n"
"              <strong>${object.pet_id.name}</strong> está prestes a receber a vacinação <strong>${object.vaccine_id.name}</strong>.\n"
"            </p>\n"
"            <p style=\"margem: 0; tamanho da fonte: 14px; cor: #856404;\">\n"
"              <strong>Data de vencimento:</strong> ${object.next_due_date}<br>\n"
"              <strong>Dias até o vencimento:</strong> ${object.days_since_vaccination} dias\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #f8f9fa; preenchimento: 15px; raio da borda: 5px; margem: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #495057;\">Informações sobre animais de estimação</h3>\n"
"            <p style=\"margin: 0;\"><strong>Nome do animal de estimação:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Espécie:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Raça:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Idade:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; preenchimento: 15px; raio da borda: 5px; margem: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">Detalhes da vacinação</h3>\n"
"            <p style=\"margin: 0;\"><strong>Vacina:</strong> ${object.vaccine_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Tipo:</strong> ${object.vaccination_type}</p>\n"
"            <p style=\"margin: 0;\"><strong>Última administração:</strong> ${object.date_administered}</p>\n"
"            <p style=\"margin: 0;\"><strong>Próximo prazo:</strong> ${object.next_due_date}</p>\n"
"          </div>\n"
"          \n"
"          <p style=\"margem: 20px 0; preenchimento: 15px; cor de fundo: #e7f3ff; borda esquerda: 4px sólido #007bff; raio da borda: 5px;\">\n"
"            <strong>Ação necessária:</strong> Entre em contato conosco para agendar a consulta de vacinação do seu animal de estimação. \n"
"            Vacinações regulares são essenciais para a saúde e o bem-estar do seu animal de estimação.\n"
"          </p>\n"
"          \n"
"          <br>\n"
"          <p style=\"margem: 0px; preenchimento: 0px; tamanho da fonte: 13px;\">\n"
"            Atenciosamente,<br>\n"
"            Equipe de gerenciamento de animais de estimação\n"
"          </p>\n"
"        </div>"

