#. module: pet_management
#: model:mail.template,body_html:pet_management.email_template_pet_notification
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dear ${object.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            ${object.message}\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-left: 4px solid #007bff; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #007bff;\">Pet Information</h3>\n"
"            <p style=\"margin: 0;\"><strong>Pet Name:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Species:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Breed:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Age:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #fff3cd; padding: 15px; border-left: 4px solid #ffc107; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_overdue'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #856404;\">⚠️ URGENT ACTION REQUIRED</h3>\n"
"            <p style=\"margin: 0; color: #856404;\">\n"
"              This is an urgent reminder. Please contact us immediately to schedule your pet's overdue vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-left: 4px solid #17a2b8; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_due'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">📅 Upcoming Vaccination</h3>\n"
"            <p style=\"margin: 0; color: #0c5460;\">\n"
"              Please schedule an appointment for your pet's upcoming vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d4edda; padding: 15px; border-left: 4px solid #28a745; margin: 20px 0;\" t-if=\"object.notification_type == 'appointment_reminder'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #155724;\">📞 Appointment Reminder</h3>\n"
"            <p style=\"margin: 0; color: #155724;\">\n"
"              Don't forget about your upcoming appointment.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            If you have any questions or need to reschedule, please contact us at your earliest convenience.\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Best regards,<br>\n"
"            Pet Management Team\n"
"          </p>\n"
"          <hr style=\"margin: 20px 0; border: none; border-top: 1px solid #dee2e6;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 11px; color: #6c757d;\">\n"
"            This is an automated notification. Please do not reply to this email.\n"
"          </p>\n"
"        </div>\n"
"      "
msgstr ""
"<div style = \"marjă: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style = \"marjă: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dragă __ph_0__,\n"
"          </p>\n"
"          <br>\n"
"          <p style = \"marjă: 0px; padding: 0px; font-size: 13px;\">\n"
"            __Ph_1__\n"
"          </p>\n"
"          <br>\n"
"          <div style = \"fundal-color: #f8f9fa; padding: 15px; front-left: 4px solid #007bff; marjă: 20px 0;\">\n"
"            <h3 style = \"marjă: 0 0 10px 0; culoare: #007bff;\"> Informații pentru animale de companie </h3>\n"
"            <p style = \"marjă: 0;\"> <strong> nume de companie: </strong> __ph_2 __ </p>\n"
"            <p style = \"marjă: 0;\"> <strong> specie: </strong> __ph_3 __ </p>\n"
"            <p style = \"marjă: 0;\"> <strong> rase: </strong> __ph_4 __ </p>\n"
"            <p style = \"marjă: 0;\"> <strong> vârsta: </strong> __ph_5 __ </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"fundal-color: #fff3cd; padding: 15px; border-left: 4px solid #ffc107; marjă: 20px 0;\" t-if = \"obiect.notification_type == 'vaccinare_overdue'\">\n"
"            <h3 style = \"marjă: 0 0 10px 0; culoare: #856404;\"> ⚠️ Acțiune urgentă necesară </h3>\n"
"            <p style = \"marjă: 0; culoare: #856404;\">\n"
"              Acesta este un memento urgent. Vă rugăm să ne contactați imediat pentru a programa vaccinarea întârziată a animalului dvs. de companie.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"fundal-color: #d1ecf1; padding: 15px; front-left: 4px solid #17a2b8; marjă: 20px 0;\" t-if = \"obiect.notification_type == 'vaccinare_due'\">\n"
"            <h3 style = \"marjă: 0 0 10px 0; culoare: #0c5460;\"> 📅 vaccinarea viitoare </h3>\n"
"            <p style = \"marjă: 0; culoare: #0c5460;\">\n"
"              Vă rugăm să programați o programare pentru vaccinarea viitoare a animalului dvs. de companie.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"fundal-color: #d4edda; padding: 15px; border-left: 4px solid #28a745; marjă: 20px 0;\" t-if = \"obiect.notification_type == 'numire_reminder'\">\n"
"            <h3 style = \"marjă: 0 0 10px 0; culoare: #155724;\"> 📞 memento de numire </h3>\n"
"            <p style = \"marjă: 0; culoare: #155724;\">\n"
"              Nu uitați de viitoarea dvs. programare.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <br>\n"
"          <p style = \"marjă: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dacă aveți întrebări sau trebuie să vă reprogramați, vă rugăm să ne contactați cât mai curând.\n"
"          </p>\n"
"          <br>\n"
"          <p style = \"marjă: 0px; padding: 0px; font-size: 13px;\">\n"
"            Salutări, <br>\n"
"            Echipa de gestionare a animalelor de companie\n"
"          </p>\n"
"          <hr style = \"marjă: 20px 0; border: none; border-top: 1px solid #dee2e6;\">\n"
"          <p style = \"marjă: 0px; padding: 0px; font-size: 11px; culoare: #6c757d;\">\n"
"            Aceasta este o notificare automată. Vă rugăm să nu răspundeți la acest e -mail.\n"
"          </p>\n"
"        </div>"

#. module: pet_management
#: model:mail.template,body_html:pet_management.email_template_vaccination_due
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dear ${object.pet_id.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #fff3cd; padding: 20px; border-left: 4px solid #ffc107; margin: 20px 0;\">\n"
"            <h2 style=\"margin: 0 0 15px 0; color: #856404;\">📅 Vaccination Due Reminder</h2>\n"
"            <p style=\"margin: 0 0 10px 0; font-size: 16px;\">\n"
"              <strong>${object.pet_id.name}</strong> is due for <strong>${object.vaccine_id.name}</strong> vaccination.\n"
"            </p>\n"
"            <p style=\"margin: 0; font-size: 14px; color: #856404;\">\n"
"              <strong>Due Date:</strong> ${object.next_due_date}<br>\n"
"              <strong>Days Until Due:</strong> ${object.days_since_vaccination} days\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #495057;\">Pet Information</h3>\n"
"            <p style=\"margin: 0;\"><strong>Pet Name:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Species:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Breed:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Age:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">Vaccination Details</h3>\n"
"            <p style=\"margin: 0;\"><strong>Vaccine:</strong> ${object.vaccine_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Type:</strong> ${object.vaccination_type}</p>\n"
"            <p style=\"margin: 0;\"><strong>Last Administered:</strong> ${object.date_administered}</p>\n"
"            <p style=\"margin: 0;\"><strong>Next Due:</strong> ${object.next_due_date}</p>\n"
"          </div>\n"
"          \n"
"          <p style=\"margin: 20px 0; padding: 15px; background-color: #e7f3ff; border-left: 4px solid #007bff; border-radius: 5px;\">\n"
"            <strong>Action Required:</strong> Please contact us to schedule your pet's vaccination appointment. \n"
"            Regular vaccinations are essential for your pet's health and well-being.\n"
"          </p>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Best regards,<br>\n"
"            Pet Management Team\n"
"          </p>\n"
"        </div>\n"
"      "
msgstr ""
"<div style = \"marjă: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style = \"marjă: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dragă __ph_0__,\n"
"          </p>\n"
"          <br>\n"
"          <div style = \"fundal-color: #fff3cd; padding: 20px; border-left: 4px solid #ffc107; marjă: 20px 0;\">\n"
"            <h2 style = \"marjă: 0 0 15px 0; culoare: #856404;\"> 📅 vaccinarea memento -ului </h2>\n"
"            <p style = \"marjă: 0 0 10px 0; font-size: 16px;\">\n"
"              <strong> __ ph_1 __ </strong> se datorează pentru <strong> __ ph_2 __ </strong> vaccinarea.\n"
"            </p>\n"
"            <p style = \"marjă: 0; font-size: 14px; culoare: #856404;\">\n"
"              <strong> Data scadenței: </strong> __ph_3__ <br>\n"
"              <strong> zile până la scadență: </strong> __ph_4__ zile\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"fundal-colo-color: #f8f9fa; padding: 15px; border-radius: 5px; marjă: 20px 0;\">\n"
"            <h3 style = \"marjă: 0 0 10px 0; culoare: #495057;\"> Informații pentru animale de companie </h3>\n"
"            <p style = \"marjă: 0;\"> <strong> nume de companie: </strong> __ph_1 __ </p>\n"
"            <p style = \"marjă: 0;\"> <strong> specie: </strong> __ph_6 __ </p>\n"
"            <p style = \"marjă: 0;\"> <strong> rase: </strong> __ph_7 __ </p>\n"
"            <p style = \"marjă: 0;\"> <strong> vârsta: </strong> __ph_8 __ </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"fundal-color: #d1ecf1; padding: 15px; radius de frontieră: 5px; marjă: 20px 0;\">\n"
"            <h3 style = \"marjă: 0 0 10px 0; culoare: #0c5460;\"> Detalii despre vaccinare </h3>\n"
"            <p style = \"marjă: 0;\"> <strong> vaccin: </strong> __ph_2 __ </p>\n"
"            <p style = \"marjă: 0;\"> <strong> tip: </strong> __ph_10 __ </p>\n"
"            <p style = \"marjă: 0;\"> <strong> ultima administrată: </strong> __ph_11 __ </p>\n"
"            <p style = \"marjă: 0;\"> <strong> următorul datorat: </strong> __ph_3 __ </p>\n"
"          </div>\n"
"          \n"
"          <p style = \"marjă: 20px 0; padding: 15px; fundal-color: #e7f3ff; front-left: 4px solid #007bff; border-radius: 5px;\">\n"
"            <strong> Acțiune necesară: </strong> Vă rugăm să ne contactați pentru a programa programarea la vaccinare a animalelor de companie. \n"
"            Vaccinările obișnuite sunt esențiale pentru sănătatea și bunăstarea animalului dvs. de companie.\n"
"          </p>\n"
"          \n"
"          <br>\n"
"          <p style = \"marjă: 0px; padding: 0px; font-size: 13px;\">\n"
"            Salutări, <br>\n"
"            Echipa de gestionare a animalelor de companie\n"
"          </p>\n"
"        </div>"

