#. module: pet_management
#: model:mail.template,body_html:pet_management.email_template_pet_notification
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dear ${object.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            ${object.message}\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-left: 4px solid #007bff; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #007bff;\">Pet Information</h3>\n"
"            <p style=\"margin: 0;\"><strong>Pet Name:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Species:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Breed:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Age:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #fff3cd; padding: 15px; border-left: 4px solid #ffc107; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_overdue'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #856404;\">⚠️ URGENT ACTION REQUIRED</h3>\n"
"            <p style=\"margin: 0; color: #856404;\">\n"
"              This is an urgent reminder. Please contact us immediately to schedule your pet's overdue vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-left: 4px solid #17a2b8; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_due'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">📅 Upcoming Vaccination</h3>\n"
"            <p style=\"margin: 0; color: #0c5460;\">\n"
"              Please schedule an appointment for your pet's upcoming vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d4edda; padding: 15px; border-left: 4px solid #28a745; margin: 20px 0;\" t-if=\"object.notification_type == 'appointment_reminder'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #155724;\">📞 Appointment Reminder</h3>\n"
"            <p style=\"margin: 0; color: #155724;\">\n"
"              Don't forget about your upcoming appointment.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            If you have any questions or need to reschedule, please contact us at your earliest convenience.\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Best regards,<br>\n"
"            Pet Management Team\n"
"          </p>\n"
"          <hr style=\"margin: 20px 0; border: none; border-top: 1px solid #dee2e6;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 11px; color: #6c757d;\">\n"
"            This is an automated notification. Please do not reply to this email.\n"
"          </p>\n"
"        </div>\n"
"      "
msgstr ""
"<див стиле = \"Маргин: 0пк; облога: 0пк; величина фонта: 13пк;\">\n"
"<п стиле = \"Маргин: 0пк; облога: 0пк; величина фонта: 13пк;\">\n"
"Драги __Х_0__,\n"
"</ п>\n"
"<бр>\n"
"<п стиле = \"Маргин: 0пк; облога: 0пк; величина фонта: 13пк;\">\n"
"__Х_1__\n"
"</ п>\n"
"<бр>\n"
"<див стиле = \"позадина-боја: # ф8ф9фа; облога: 15пк; гранично лево: 4пк чврсти # 007БФФ; маргина: 20пк 0;\"\n"
"<х3 стиле = \"Маргин: 0 0 10пк 0; боја: # 007бфф;\"> Информације о кућним љубимцима </ х3>\n"
"<п стиле = \"Маргин: 0;\"> <стронг> Име кућних љубимаца: </ стронг> __Х_2 __ </ п>\n"
"<п стиле = \"маргина: 0;\"> <стронг> врсте: </ стронг> __Х_3 __ </ п>\n"
"<п стиле = \"Маргин: 0;\"> <стронг> пасмина: </ стронг> __Х_4 __ </ п>\n"
"<п стиле = \"маргина: 0;\"> <стронг> Старост: </ стронг> __Х_5 __ </ п>\n"
"</ див>\n"
"\n"
"<див стиле = \"позадина-боја: # ффф3цд; облога: 15пк; гранична левица: 4пк чврсти супстанца # ФФЦ107; Маргин: 20пк 0;\"Т-ИФ = \"Објецт.Натифицатион_типе == 'ваццинатион_овердуе'\">\n"
"<х3 стиле = \"маргина: 0 0 10пк 0; боја: # 856404;\"> ⚠ хитна акција је потребна </ х3>\n"
"<п стиле = \"Маргин: 0; боја: # 856404;\">\n"
"Ово је хитан подсетник.Молимо контактирајте нас одмах да бисте заказали рок вакцинације вашег љубимца.\n"
"</ п>\n"
"</ див>\n"
"\n"
"<див стиле = \"позадина-боја: # д1ецф1; облога: 15пк; гранично лево: 4пк чврсти рад # 17а2б8; маргина: 20пк 0;\"Т-ИФ = \"Објецт.Натифицатион_типе == 'вакцинација_дуе'\">\n"
"<х3 стиле = \"Маргин: 0 0 10пк 0; боја: # 0ц5460;\"> 📅 Предстојеће вакцинација </ х3>\n"
"<п стиле = \"Маргин: 0; боја: # 0ц5460;\">\n"
"Закажите састанак за предстојећу вакцинацију вашег љубимца.\n"
"</ п>\n"
"</ див>\n"
"\n"
"<див стиле = \"Позадина-боја: # Д4ЕДДА; Облога: 15пк; гранична левица: 4пк Чврсти # 28А745; Маргин: 20пк 0;\"Т-ИФ = \"Објецт.Натифицатион_типе == 'Именовање_Реминдер'\">\n"
"<Х3 Стиле = \"Маргин: 0 0 10пк 0; боја: # 155724;\"> 📞 Подсетник за именовање </ х3>\n"
"<п стиле = \"Маргин: 0; боја: # 155724;\">\n"
"Не заборавите на свој предстојећи састанак.\n"
"</ п>\n"
"</ див>\n"
"\n"
"<бр>\n"
"<п стиле = \"Маргин: 0пк; облога: 0пк; величина фонта: 13пк;\">\n"
"Ако имате било каквих питања или потребе да се одложите, контактирајте нас у најранијој пракси.\n"
"</ п>\n"
"<бр>\n"
"<п стиле = \"Маргин: 0пк; облога: 0пк; величина фонта: 13пк;\">\n"
"Срдачан поздрав, <бр>\n"
"Теам за управљање кућним љубимцима\n"
"</ п>\n"
"<хр стиле = \"Маргин: 20пк 0; граница: ниједна; гранична топ: 1пк чврст # дее2е6;\">\n"
"<п стиле = \"маргина: 0пк; облога: 0пк; фонт-сизе: 11пк; боја: # 6ц757д;\">\n"
"Ово је аутоматизовано обавештење.Молим вас, не одговарајте на овај емаил.\n"
"</ п>\n"
"</ див>"

#. module: pet_management
#: model:mail.template,body_html:pet_management.email_template_vaccination_due
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dear ${object.pet_id.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #fff3cd; padding: 20px; border-left: 4px solid #ffc107; margin: 20px 0;\">\n"
"            <h2 style=\"margin: 0 0 15px 0; color: #856404;\">📅 Vaccination Due Reminder</h2>\n"
"            <p style=\"margin: 0 0 10px 0; font-size: 16px;\">\n"
"              <strong>${object.pet_id.name}</strong> is due for <strong>${object.vaccine_id.name}</strong> vaccination.\n"
"            </p>\n"
"            <p style=\"margin: 0; font-size: 14px; color: #856404;\">\n"
"              <strong>Due Date:</strong> ${object.next_due_date}<br>\n"
"              <strong>Days Until Due:</strong> ${object.days_since_vaccination} days\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #495057;\">Pet Information</h3>\n"
"            <p style=\"margin: 0;\"><strong>Pet Name:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Species:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Breed:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Age:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">Vaccination Details</h3>\n"
"            <p style=\"margin: 0;\"><strong>Vaccine:</strong> ${object.vaccine_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Type:</strong> ${object.vaccination_type}</p>\n"
"            <p style=\"margin: 0;\"><strong>Last Administered:</strong> ${object.date_administered}</p>\n"
"            <p style=\"margin: 0;\"><strong>Next Due:</strong> ${object.next_due_date}</p>\n"
"          </div>\n"
"          \n"
"          <p style=\"margin: 20px 0; padding: 15px; background-color: #e7f3ff; border-left: 4px solid #007bff; border-radius: 5px;\">\n"
"            <strong>Action Required:</strong> Please contact us to schedule your pet's vaccination appointment. \n"
"            Regular vaccinations are essential for your pet's health and well-being.\n"
"          </p>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Best regards,<br>\n"
"            Pet Management Team\n"
"          </p>\n"
"        </div>\n"
"      "
msgstr ""
"<див стиле = \"Маргин: 0пк; облога: 0пк; величина фонта: 13пк;\">\n"
"<п стиле = \"Маргин: 0пк; облога: 0пк; величина фонта: 13пк;\">\n"
"Драги __Х_0__,\n"
"</ п>\n"
"<бр>\n"
"<див стиле = \"позадина-боја: # ффф3цд; облога: 20пк; гранична левица: 4пк чврсти супстанца # ФФЦ107; Маргин: 20пк 0;\">\n"
"<х2 стиле = \"Маргин: 0 0 15пк 0; боја: # 856404;\"> 📅 подсетник за вакцинацију </ х2>\n"
"<п стиле = \"Маргин: 0 0 10пк 0; величина фонта: 16пк;\">\n"
"<стронг> __ пХ_1 __ </ стронг> треба да буде за <стронг> __ пХ_2 __ </ стронг> вакцинација.\n"
"</ п>\n"
"<п стиле = \"маргина: 0; величина фонта: 14пк; боја: # 856404;\">\n"
"<стронг> Датум рока: </ стронг> __Х_3__ <бр>\n"
"<стронг> Дани до доспјела: </ стронг> __фх_4__ дана\n"
"</ п>\n"
"</ див>\n"
"\n"
"<ДИВ СТИЛЕ = \"БОЈА БОЈА: # Ф8Ф9ФА; Облога: 15пк; у радијусу у граничном делу: 5пк; маргина: 20пк 0;\">\n"
"<х3 стиле = \"Маргин: 0 0 10пк 0; боја: # 495057;\"> Информације о кућним љубимцима </ х3>\n"
"<п стиле = \"маргина: 0;\"> <стронг> Име кућних љубимаца: </ стронг> __Х_1 __ </ п>\n"
"<п стиле = \"Маргин: 0;\"> <стронг> врсте: </ стронг> __Х_6 __ </ п>\n"
"<п стиле = \"Маргин: 0;\"> <стронг> пасмина: </ стронг> __пх_7 __ </ п>\n"
"<п стиле = \"Маргин: 0;\"> <стронг> Старост: </ стронг> __Х_8 __ </ п>\n"
"</ див>\n"
"\n"
"<див стиле = \"позадина-боја: # д1ецф1; облога: 15пк; радијус у границу: 5пк; марљива: 20пк 0;\">\n"
"<х3 стиле = \"Маргин: 0 0 10пк 0; боја: # 0ц5460;\"> Детаљи вакцинације </ х3>\n"
"<п стиле = \"маргина: 0;\"> <стронг> вакцина: </ стронг> __Х_2 __ </ п>\n"
"<п стиле = \"Маргин: 0;\"> <стронг> Тип: </ стронг> __Х_10 __ </ п>\n"
"<п стиле = \"маргина: 0;\"> <стронг> Последњи администрирани: </ стронг> __Х_11 __ </ п>\n"
"<п стиле = \"Маргин: 0;\"> <стронг> Следеће Дуе: </ стронг> __Х_3 __ </ п>\n"
"</ див>\n"
"\n"
"<п стиле = \"маргина: 20пк 0; облога: 15пк; позадина-боја: # Е7Ф3ФФ; гранична левица: 4пк чврсти # 007БФФ; Бордер-радијус: 5пк;\"\n"
"<стронг> Потребна акција: </ стронг> Молимо контактирајте нас да бисте заказали састанак вакцинације вашег љубимца.\n"
"Редовне вакцинације су неопходне за здравље и добробит вашег љубимца.\n"
"</ п>\n"
"\n"
"<бр>\n"
"<п стиле = \"Маргин: 0пк; облога: 0пк; величина фонта: 13пк;\">\n"
"Срдачан поздрав, <бр>\n"
"Теам за управљање кућним љубимцима\n"
"</ п>\n"
"</ див>"

