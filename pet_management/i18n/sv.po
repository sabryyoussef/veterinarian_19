#: model:mail.template,body_html:pet_management.email_template_pet_notification
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dear ${object.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            ${object.message}\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-left: 4px solid #007bff; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #007bff;\">Pet Information</h3>\n"
"            <p style=\"margin: 0;\"><strong>Pet Name:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Species:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Breed:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Age:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #fff3cd; padding: 15px; border-left: 4px solid #ffc107; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_overdue'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #856404;\">⚠️ URGENT ACTION REQUIRED</h3>\n"
"            <p style=\"margin: 0; color: #856404;\">\n"
"              This is an urgent reminder. Please contact us immediately to schedule your pet's overdue vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-left: 4px solid #17a2b8; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_due'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">📅 Upcoming Vaccination</h3>\n"
"            <p style=\"margin: 0; color: #0c5460;\">\n"
"              Please schedule an appointment for your pet's upcoming vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d4edda; padding: 15px; border-left: 4px solid #28a745; margin: 20px 0;\" t-if=\"object.notification_type == 'appointment_reminder'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #155724;\">📞 Appointment Reminder</h3>\n"
"            <p style=\"margin: 0; color: #155724;\">\n"
"              Don't forget about your upcoming appointment.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            If you have any questions or need to reschedule, please contact us at your earliest convenience.\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Best regards,<br>\n"
"            Pet Management Team\n"
"          </p>\n"
"          <hr style=\"margin: 20px 0; border: none; border-top: 1px solid #dee2e6;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 11px; color: #6c757d;\">\n"
"            This is an automated notification. Please do not reply to this email.\n"
"          </p>\n"
"        </div>\n"
"      "
msgstr ""
"<div style = \"marginal: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style = \"marginal: 0px; padding: 0px; font-size: 13px;\">\n"
"            Kära __ph_0__,\n"
"          </p>\n"
"          <br>\n"
"          <p style = \"marginal: 0px; padding: 0px; font-size: 13px;\">\n"
"            __Ph_1__\n"
"          </p>\n"
"          <br>\n"
"          <div style = \"bakgrundsfärg: #f8f9fa; padding: 15px; gräns-vänster: 4px fast #007bff; marginal: 20px 0;\">\n"
"            <h3 style = \"marginal: 0 0 10px 0; färg: #007bff;\"> PET -information </h3>\n"
"            <p style = \"marginal: 0;\"> <strong> husdjurnamn: </strong> __ph_2 __ </p>\n"
"            <p stil = \"marginal: 0;\"> <strong> art: </strong> __ph_3 __ </p>\n"
"            <p style = \"marginal: 0;\"> <strong> ras: </strong> __ph_4 __ </p>\n"
"            <p style = \"marginal: 0;\"> <strong> ålder: </strong> __ph_5 __ </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"bakgrundsfärg: #fff3cd; padding: 15px; gräns-vänster: 4px solid #ffc107; marginal: 20px 0;\" t-if = \"objekt.notification_type == 'vaccination_overdue'\">\n"
"            <h3 style = \"marginal: 0 0 10px 0; färg: #856404;\"> ⚠ brådskande åtgärder krävs </h3>\n"
"            <p stil = \"marginal: 0; färg: #856404;\">\n"
"              Detta är en brådskande påminnelse. Kontakta oss omedelbart för att schemalägga ditt husdjurs förfallna vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"bakgrundsfärg: #d1ecf1; padding: 15px; gräns-vänster: 4px solid #17a2b8; marginal: 20px 0;\" t-if = \"objekt.notification_type == 'vaccination_due'\">\n"
"            <h3 style = \"marginal: 0 0 10px 0; färg: #0c5460;\"> 📅 Kommande vaccination </h3>\n"
"            <p stil = \"marginal: 0; färg: #0c5460;\">\n"
"              Vänligen schemalägga ett möte för ditt husdjurs kommande vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"bakgrundsfärg: #d4edda; padding: 15px; gräns-vänster: 4px solid #28a745; marginal: 20px 0;\" t-if = \"objekt.notification_type == 'utnämningen_reminder'\">\n"
"            <h3 style = \"marginal: 0 0 10px 0; färg: #155724;\"> 📞 utnämningen påminnelse </h3>\n"
"            <p stil = \"marginal: 0; färg: #155724;\">\n"
"              Glöm inte din kommande möte.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <br>\n"
"          <p style = \"marginal: 0px; padding: 0px; font-size: 13px;\">\n"
"            Om du har några frågor eller behöver omplanera, vänligen kontakta oss så snart som möjligt.\n"
"          </p>\n"
"          <br>\n"
"          <p style = \"marginal: 0px; padding: 0px; font-size: 13px;\">\n"
"            Med vänliga hälsningar, <br>\n"
"            Husdjursledningsteam\n"
"          </p>\n"
"          <hr stil = \"marginal: 20px 0; gräns: ingen; gräns-topp: 1px fast #dee2e6;\">\n"
"          <p stil = \"marginal: 0px; padding: 0px; font-size: 11px; färg: #6c757d;\">\n"
"            Detta är en automatiserad anmälan. Svara inte på det här e -postmeddelandet.\n"
"          </p>\n"
"        </div>"

#. module: pet_management
#: model:mail.template,body_html:pet_management.email_template_vaccination_due
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dear ${object.pet_id.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #fff3cd; padding: 20px; border-left: 4px solid #ffc107; margin: 20px 0;\">\n"
"            <h2 style=\"margin: 0 0 15px 0; color: #856404;\">📅 Vaccination Due Reminder</h2>\n"
"            <p style=\"margin: 0 0 10px 0; font-size: 16px;\">\n"
"              <strong>${object.pet_id.name}</strong> is due for <strong>${object.vaccine_id.name}</strong> vaccination.\n"
"            </p>\n"
"            <p style=\"margin: 0; font-size: 14px; color: #856404;\">\n"
"              <strong>Due Date:</strong> ${object.next_due_date}<br>\n"
"              <strong>Days Until Due:</strong> ${object.days_since_vaccination} days\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #495057;\">Pet Information</h3>\n"
"            <p style=\"margin: 0;\"><strong>Pet Name:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Species:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Breed:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Age:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">Vaccination Details</h3>\n"
"            <p style=\"margin: 0;\"><strong>Vaccine:</strong> ${object.vaccine_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Type:</strong> ${object.vaccination_type}</p>\n"
"            <p style=\"margin: 0;\"><strong>Last Administered:</strong> ${object.date_administered}</p>\n"
"            <p style=\"margin: 0;\"><strong>Next Due:</strong> ${object.next_due_date}</p>\n"
"          </div>\n"
"          \n"
"          <p style=\"margin: 20px 0; padding: 15px; background-color: #e7f3ff; border-left: 4px solid #007bff; border-radius: 5px;\">\n"
"            <strong>Action Required:</strong> Please contact us to schedule your pet's vaccination appointment. \n"
"            Regular vaccinations are essential for your pet's health and well-being.\n"
"          </p>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Best regards,<br>\n"
"            Pet Management Team\n"
"          </p>\n"
"        </div>\n"
"      "
msgstr ""
"<div style = \"marginal: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style = \"marginal: 0px; padding: 0px; font-size: 13px;\">\n"
"            Kära __ph_0__,\n"
"          </p>\n"
"          <br>\n"
"          <div style = \"bakgrundsfärg: #fff3cd; padding: 20px; gräns-vänster: 4px solid #ffc107; marginal: 20px 0;\">\n"
"            <h2 style = \"marginal: 0 0 15px 0; färg: #856404;\"> 📅 Vaccination påminnelse </h2>\n"
"            <p style = \"marginal: 0 0 10px 0; font-size: 16px;\">\n"
"              <strong> __ PH_1 __ </strong> beror på <strong> __ PH_2 __ </strong> vaccination.\n"
"            </p>\n"
"            <p style = \"marginal: 0; font-size: 14px; färg: #856404;\">\n"
"              <strong> förfallodatum: </strong> __ph_3__ <br>\n"
"              <strong> dagar fram till förfallet: </strong> __ph_4__ dagar\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"bakgrundsfärg: #f8f9fa; padding: 15px; gräns-radius: 5px; marginal: 20px 0;\">\n"
"            <h3 style = \"marginal: 0 0 10px 0; färg: #495057;\"> Petinformation </h3>\n"
"            <p style = \"marginal: 0;\"> <strong> husdjurnamn: </strong> __ph_1 __ </p>\n"
"            <p style = \"marginal: 0;\"> <strong> art: </strong> __ph_6 __ </p>\n"
"            <p style = \"marginal: 0;\"> <strong> ras: </strong> __ph_7 __ </p>\n"
"            <p style = \"marginal: 0;\"> <strong> ålder: </strong> __ph_8 __ </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"bakgrundsfärg: #d1ecf1; padding: 15px; gräns-radius: 5px; marginal: 20px 0;\">\n"
"            <h3 style = \"marginal: 0 0 10px 0; färg: #0c5460;\"> Vaccinationsdetaljer </h3>\n"
"            <p style = \"marginal: 0;\"> <strong> Vaccin: </strong> __ph_2 __ </p>\n"
"            <p style = \"marginal: 0;\"> <strong> typ: </strong> __ph_10 __ </p>\n"
"            <p style = \"marginal: 0;\"> <strong> senast administrerad: </strong> __ph_11 __ </p>\n"
"            <p style = \"marginal: 0;\"> <strong> Nästa förfallna: </strong> __ph_3 __ </p>\n"
"          </div>\n"
"          \n"
"          <p style = \"marginal: 20px 0; padding: 15px; bakgrund-färg: #e7f3ff; gräns-vänster: 4px solid #007bff; gräns-radius: 5px;\">\n"
"            <strong> Åtgärd krävs: </strong> Vänligen kontakta oss för att schemalägga ditt husdjurs vaccinationsmöte. \n"
"            Regelbundna vaccinationer är viktiga för ditt husdjurs hälsa och välbefinnande.\n"
"          </p>\n"
"          \n"
"          <br>\n"
"          <p style = \"marginal: 0px; padding: 0px; font-size: 13px;\">\n"
"            Med vänliga hälsningar, <br>\n"
"            Husdjursledningsteam\n"
"          </p>\n"
"        </div>"

