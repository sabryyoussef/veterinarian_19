#: model:mail.template,body_html:pet_management.email_template_pet_notification
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Dear ${object.owner_id.name or 'Pet Owner'},\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            ${object.message}\n"
"          </p>\n"
"          <br>\n"
"          <div style=\"background-color: #f8f9fa; padding: 15px; border-left: 4px solid #007bff; margin: 20px 0;\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #007bff;\">Pet Information</h3>\n"
"            <p style=\"margin: 0;\"><strong>Pet Name:</strong> ${object.pet_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Species:</strong> ${object.pet_id.species_id.name}</p>\n"
"            <p style=\"margin: 0;\"><strong>Breed:</strong> ${object.pet_id.breed_id.name or 'Mixed'}</p>\n"
"            <p style=\"margin: 0;\"><strong>Age:</strong> ${object.pet_id.age_display}</p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #fff3cd; padding: 15px; border-left: 4px solid #ffc107; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_overdue'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #856404;\">⚠️ URGENT ACTION REQUIRED</h3>\n"
"            <p style=\"margin: 0; color: #856404;\">\n"
"              This is an urgent reminder. Please contact us immediately to schedule your pet's overdue vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d1ecf1; padding: 15px; border-left: 4px solid #17a2b8; margin: 20px 0;\" t-if=\"object.notification_type == 'vaccination_due'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #0c5460;\">📅 Upcoming Vaccination</h3>\n"
"            <p style=\"margin: 0; color: #0c5460;\">\n"
"              Please schedule an appointment for your pet's upcoming vaccination.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style=\"background-color: #d4edda; padding: 15px; border-left: 4px solid #28a745; margin: 20px 0;\" t-if=\"object.notification_type == 'appointment_reminder'\">\n"
"            <h3 style=\"margin: 0 0 10px 0; color: #155724;\">📞 Appointment Reminder</h3>\n"
"            <p style=\"margin: 0; color: #155724;\">\n"
"              Don't forget about your upcoming appointment.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            If you have any questions or need to reschedule, please contact us at your earliest convenience.\n"
"          </p>\n"
"          <br>\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"            Best regards,<br>\n"
"            Pet Management Team\n"
"          </p>\n"
"          <hr style=\"margin: 20px 0; border: none; border-top: 1px solid #dee2e6;\">\n"
"          <p style=\"margin: 0px; padding: 0px; font-size: 11px; color: #6c757d;\">\n"
"            This is an automated notification. Please do not reply to this email.\n"
"          </p>\n"
"        </div>\n"
"      "
msgstr ""
"<div style = \"margin: 0px; padding: 0px; шрифт-розмір: 13px;\">\n"
"          <p style = \"маржа: 0px; прокладка: 0px; шрифт-розмір: 13px;\">\n"
"            Шановний __ph_0__,\n"
"          </p>\n"
"          <br>\n"
"          <p style = \"маржа: 0px; прокладка: 0px; шрифт-розмір: 13px;\">\n"
"            __Ph_1__\n"
"          </p>\n"
"          <br>\n"
"          <div style = \"Фоновий колір: #f8f9fa; padding: 15px; кордон-лівий: 4px суцільний #007bff; маржа: 20px 0;\">> \">>\"> \">\"> \">\"> \">\n"
"            <H3 style = \"Маржа: 0 0 10px 0; колір: #007bff;\"> Інформація про домашні тварини </h3>\n"
"            <p style = \"margin: 0;\"> <strong> ім'я домашнього улюбленця: </strong> __ph_2 __ </p>\n"
"            <P style = \"Позначка: 0;\"> <strong> види: </strong> __ph_3 __ </p>\n"
"            <p style = \"margin: 0;\"> <strong> порода: </strong> __ph_4 __ </p>\n"
"            <p style = \"margin: 0;\"> <strong> вік: </strong> __ph_5 __ </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"Фоновий колір: #fff3cd; прокладка: 15px; кордон-лівий: 4px суцільний #ffc107; маржа: 20px 0;\" t-if = \"Object.notification_type == 'вакцинація_overdue'>>\n"
"            <H3 style = \"Маржа: 0 0 10px 0; Колір: #856404;\"> ⚠ Необхідні дії </h3>\n"
"            <p style = \"margin: 0; колір: #856404;\">\n"
"              Це нагальне нагадування. Будь ласка, зв'яжіться з нами негайно, щоб запланувати прострочену щеплення вашого вихованця.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"фоновий колір: #d1ecf1; padding: 15px; кордон-лівий: 4px суцільний #17a2b8; маржа: 20px 0;\" t-if = \"Object.notification_type == 'вакцинація_due'>>\n"
"            <H3 style = \"Маржа: 0 0 10px 0; колір: #0c5460;\"> 📅 майбутня вакцинація </h3>\n"
"            <p style = \"margin: 0; колір: #0c5460;\">\n"
"              Будь ласка, заплануйте зустріч на майбутню вакцинацію вашого вихованця.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <div style = \"Фоновий колір: #d4Edda; Полоска: 15px; кордон-лівий: 4px Суцільний #28a745; маржа: 20px 0;\" t-if = \"Object.notification_type == 'Deagment_reminder'\">\n"
"            <H3 style = \"Маржа: 0 0 10px 0; колір: #155724;\"> 📞 Нагадування про зустріч </h3>\n"
"            <p style = \"Позначка: 0; колір: #155724;\">\n"
"              Не забувайте про свою майбутню зустріч.\n"
"            </p>\n"
"          </div>\n"
"          \n"
"          <br>\n"
"          <p style = \"маржа: 0px; прокладка: 0px; шрифт-розмір: 13px;\">\n"
"            Якщо у вас є якісь питання або вам потрібно перенесення, будь ласка, зв'яжіться з нами якнайшвидше.\n"
"          </p>\n"
"          <br>\n"
"          <p style = \"маржа: 0px; прокладка: 0px; шрифт-розмір: 13px;\">\n"
"            З найкращими побажаннями, <br>\n"
"            Команда з управління домашніми тваринами\n"
"          </p>\n"
"          <hr style = \"margin: 20px 0; кордон: жодна; прикордонна вершина: 1px суцільна #dee2e6;\">\n"
"          <p style = \"margin: 0px; padding: 0px; шрифт-розмір: 11px; колір: #6c757d;\">\n"
"            Це автоматизоване повідомлення. Будь ласка, не відповідайте на цей електронний лист.\n"
"          </p>\n"
"        </div>"

#. module: pet_management
#: model:mail.template,body_html:pet_management.email_template_vaccination_due
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
