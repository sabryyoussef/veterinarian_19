        <!-- Core Category -->
        <record id="pet_core_category" model="ir.module.category">
            <field name="name">[ Pet ] Core</field>
            <field name="sequence">10</field>
        </record>

        <record model="res.groups.privilege" id="pet_core_privilege">
            <field name="name">Pet Core</field>
            <field name="sequence">9</field>
            <field name="category_id" ref="pet_management.pet_core_category"/>
        </record>

        <record id="group_pet_core_user_own" model="res.groups">
            <field name="name">User: Own Data</field>
            <field name="privilege_id" ref="pet_management.pet_core_privilege"/>
            <field name="comment">Can only access their own core pet data</field>
        </record>
        
        <record id="group_pet_core_user_all" model="res.groups">
            <field name="name">User: All Data</field>
            <field name="privilege_id" ref="pet_management.pet_core_privilege"/>
            <field name="implied_ids" eval="[(4, ref('group_pet_core_user_own'))]"/>
            <field name="comment">Can access all core pet data</field>
        </record>
        
        <record id="group_pet_core_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="privilege_id" ref="pet_management.pet_core_privilege"/>
            <field name="implied_ids" eval="[(4, ref('group_pet_core_user_all'))]"/>
            <field name="comment">Full administrative access to core pet management</field>
        </record>
