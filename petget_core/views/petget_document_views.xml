<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Search -->
    <record id="petget_core_view_search_document" model="ir.ui.view">
        <field name="name">petget.document.search</field>
        <field name="model">petget.document</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Title"/>
                <field name="animal_id"/>
                <field name="category"/>
                <separator/>
                <filter name="group_category" string="Category" context="{'group_by': 'category'}"/>
                <filter name="group_animal" string="Animal" context="{'group_by': 'animal_id'}"/>
            </search>
        </field>
    </record>

    <!-- List -->
    <record id="petget_core_view_list_document" model="ir.ui.view">
        <field name="name">petget.document.list</field>
        <field name="model">petget.document</field>
        <field name="arch" type="xml">
            <list>
                <field name="upload_date"/>
                <field name="name"/>
                <field name="animal_id"/>
                <field name="category"/>
                <field name="issue_date"/>
                <field name="expiry_date"/>
                <field name="uploaded_by_id" optional="show"/>
                <field name="file" filename="file_name" widget="binary"/>
                <field name="file_name" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="petget_core_view_form_document" model="ir.ui.view">
        <field name="name">petget.document.form</field>
        <field name="model">petget.document</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. 2026 Rabies Certificate"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="animal_id"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="issue_date"/>
                            <field name="expiry_date"/>
                            <field name="uploaded_by_id"/>
                            <field name="upload_date"/>
                        </group>
                    </group>
                    <group string="File">
                        <field name="file" filename="file_name" nolabel="1"/>
                        <field name="file_name" invisible="1"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" placeholder="Optional notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="petget_core_action_document" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="res_model">petget.document</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="petget_core_view_search_document"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Upload your first document</p>
            <p>Store pedigree certificates, vaccination records, microchip papers and more — linked to each animal.</p>
        </field>
    </record>

</odoo>
