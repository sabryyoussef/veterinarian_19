<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="petget_dog_view_search_breed" model="ir.ui.view">
        <field name="name">petget.dog.breed.search</field>
        <field name="model">petget.dog.breed</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="akc_group"/>
                <separator/>
                <filter name="group_akc_group" string="AKC Group" context="{'group_by': 'akc_group'}"/>
                <filter name="group_size" string="Size" context="{'group_by': 'size'}"/>
            </search>
        </field>
    </record>

    <record id="petget_dog_view_list_breed" model="ir.ui.view">
        <field name="name">petget.dog.breed.list</field>
        <field name="model">petget.dog.breed</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="akc_group"/>
                <field name="size"/>
            </list>
        </field>
    </record>

    <record id="petget_dog_view_form_breed" model="ir.ui.view">
        <field name="name">petget.dog.breed.form</field>
        <field name="model">petget.dog.breed</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Labrador Retriever"/></h1>
                    </div>
                    <group>
                        <field name="akc_group"/>
                        <field name="size"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="petget_dog_action_breed" model="ir.actions.act_window">
        <field name="name">Dog Breeds</field>
        <field name="res_model">petget.dog.breed</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="petget_dog_view_search_breed"/>
    </record>

</odoo>
