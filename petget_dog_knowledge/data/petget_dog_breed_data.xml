        <record id="petget_dog.breed_labrador_retriever" model="petget.dog.breed">
            <field name="temperament">Friendly, outgoing, eager to please</field>
            <field name="description">One of the world's most popular family and working dogs — gentle, trainable and food-motivated.</field>
            <field name="weight_min_kg">25</field><field name="weight_max_kg">36</field>
            <field name="height_min_cm">55</field><field name="height_max_cm">62</field>
            <field name="life_expectancy_min">10</field><field name="life_expectancy_max">12</field>
            <field name="grooming_need">low</field><field name="shedding_level">high</field>
            <field name="exercise_need">high</field><field name="trainability">high</field>
            <field name="common_health_issues">Hip &amp; elbow dysplasia, obesity, eye conditions (PRA), exercise-induced collapse.</field>
            <field name="first_heat_age_months">10</field><field name="avg_litter_size">7</field>
        </record>

        <record id="petget_dog.breed_golden_retriever" model="petget.dog.breed">
