<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_petspot_clinic_slot_list" model="ir.ui.view">
        <field name="name">petspot.clinic.slot.list</field>
        <field name="model">petspot.clinic.slot</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="start_datetime"/>
                <field name="end_datetime"/>
                <field name="capacity"/>
                <field name="booked_count"/>
                <field name="is_available"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_petspot_clinic_slot" model="ir.actions.act_window">
        <field name="name">Booking Slots</field>
        <field name="res_model">petspot.clinic.slot</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_petspot_submit_log_list" model="ir.ui.view">
        <field name="name">petspot.portal.submit.log.list</field>
        <field name="model">petspot.portal.submit.log</field>
        <field name="arch" type="xml">
            <list create="false" edit="false">
                <field name="submit_time"/>
                <field name="submit_type"/>
                <field name="phone"/>
                <field name="partner_id"/>
                <field name="pet_id"/>
                <field name="appointment_id"/>
                <field name="medical_visit_id"/>
                <field name="source"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

    <record id="action_petspot_submit_log" model="ir.actions.act_window">
        <field name="name">Portal Submit Log</field>
        <field name="res_model">petspot.portal.submit.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
