<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_petspot_portal_token_list" model="ir.ui.view">
        <field name="name">petspot.portal.token.list</field>
        <field name="model">petspot.portal.token</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="role"/>
                <field name="state"/>
                <field name="expires_at"/>
                <field name="chatwoot_conversation_id"/>
                <field name="appointment_id"/>
                <field name="pet_id"/>
            </list>
        </field>
    </record>

    <record id="view_petspot_portal_token_form" model="ir.ui.view">
        <field name="name">petspot.portal.token.form</field>
        <field name="model">petspot.portal.token</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_url" type="object" string="Open Portal Link" class="btn-primary"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="role"/>
                            <field name="short_code" readonly="1"/>
                            <field name="token" readonly="1" groups="base.group_no_one"/>
                            <field name="access_url" widget="url" string="Short link"/>
                            <field name="expires_at"/>

                        </group>
                        <group>
                            <field name="chatwoot_conversation_id"/>
                            <field name="chatwoot_inbox_id"/>
                            <field name="partner_id"/>
                            <field name="pet_id"/>
                            <field name="appointment_id"/>
                            <field name="medical_visit_id"/>
                            <field name="exam_token_id"/>
                            <field name="exam_access_url" widget="url"/>
                            <field name="odoo_case_url" widget="url"/>
                        </group>
                    </group>
                    <group>
                        <field name="prefill_owner_name"/>
                        <field name="prefill_phone"/>
                        <field name="prefill_pet_name"/>
                        <field name="result_summary"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_petspot_portal_token" model="ir.actions.act_window">
        <field name="name">Portal Tokens</field>
        <field name="res_model">petspot.portal.token</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
