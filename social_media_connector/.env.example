# Social Media Connector — Facebook / Odoo Social Marketing
# Copy to .env and fill in your values (do not commit .env)
#
# Odoo Online has the standard Social Marketing app with Facebook connected.
# Run: python3 scripts/discover_pages.py  →  fill FACEBOOK_PAGE_N_* below

# --- Odoo Online (primary) ---
# JSON-RPC base URL only — no /odoo path suffix
ODOO_URL=https://deebvet.odoo.com
ODOO_DB=deebvet
ODOO_USERNAME=your-odoo-login@email.com
ODOO_API_KEY=
ODOO_PASSWORD=

# --- Local Odoo (optional — dev/testing) ---
LOCAL_ODOO_URL=http://127.0.0.1:8027
LOCAL_ODOO_DB=pet_spot_elsahel
LOCAL_ODOO_USERNAME=admin
LOCAL_ODOO_PASSWORD=admin

# Target: local | remote
CONNECTOR_TARGET=remote

# Campaign marker for idempotent scheduling (prefix in social.post message)
CAMPAIGN_PREFIX=[PetSpot FB]

# --- Meta / Facebook Developer App (optional for v1) ---
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v23.0
META_USER_ACCESS_TOKEN=

# --- Facebook Pages (fill via discover_pages.py) ---
FACEBOOK_PAGE_1_NAME=PetSpot / Animal Care Center
FACEBOOK_PAGE_1_ID=
FACEBOOK_PAGE_1_URL=https://www.facebook.com/animalcarecenterpetspots/
FACEBOOK_PAGE_1_ACCESS_TOKEN=
FACEBOOK_PAGE_1_ODOO_ACCOUNT_ID=

FACEBOOK_PAGE_2_NAME=
FACEBOOK_PAGE_2_ID=
FACEBOOK_PAGE_2_URL=
FACEBOOK_PAGE_2_ACCESS_TOKEN=
FACEBOOK_PAGE_2_ODOO_ACCOUNT_ID=

FACEBOOK_PAGE_3_NAME=
FACEBOOK_PAGE_3_ID=
FACEBOOK_PAGE_3_URL=
FACEBOOK_PAGE_3_ACCESS_TOKEN=
FACEBOOK_PAGE_3_ODOO_ACCOUNT_ID=

FACEBOOK_DEFAULT_PAGE=1

# Odoo Social models: social.account, social.post, social.live.post
# Modules on Online: social, social_facebook
