<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="automation_sync_petget_breed" model="base.automation">
        <field name="name">Pet: sync AKC breed to clinic breed</field>
        <field name="model_id" ref="veterinary_clinic.x_pets_model"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(4, ref('veterinary_petget_bridge.field_x_pets_petget_breed'))]"/>
        <field name="action_server_ids" eval="[(4, ref('veterinary_petget_bridge.action_sync_petget_breed_to_x_breed'))]"/>
    </record>

    <record id="automation_sync_x_breed" model="base.automation">
        <field name="name">Pet: sync clinic breed to AKC breed</field>
        <field name="model_id" ref="veterinary_clinic.x_pets_model"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(4, ref('veterinary_clinic.x_breed_pets_model_field'))]"/>
        <field name="action_server_ids" eval="[(4, ref('veterinary_petget_bridge.action_sync_x_breed_to_petget'))]"/>
    </record>

</odoo>
