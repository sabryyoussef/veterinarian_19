<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_x_pet_documents" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="res_model">petget.document</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('x_pet_id', '=', active_id)]</field>
        <field name="context">{'default_x_pet_id': active_id}</field>
    </record>

    <record id="action_x_pet_reminders" model="ir.actions.act_window">
        <field name="name">Reminders</field>
        <field name="res_model">petget.reminder</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('x_pet_id', '=', active_id)]</field>
        <field name="context">{'default_x_pet_id': active_id}</field>
    </record>

    <record id="action_x_pet_notes" model="ir.actions.act_window">
        <field name="name">Activity Timeline</field>
        <field name="res_model">petget.note</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('x_pet_id', '=', active_id)]</field>
        <field name="context">{'default_x_pet_id': active_id}</field>
    </record>

    <record id="action_all_pet_documents" model="ir.actions.act_window">
        <field name="name">Pet Documents</field>
        <field name="res_model">petget.document</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('x_pet_id', '!=', False)]</field>
        <field name="context">{}</field>
    </record>

    <record id="action_all_pet_reminders" model="ir.actions.act_window">
        <field name="name">Pet Reminders</field>
        <field name="res_model">petget.reminder</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('x_pet_id', '!=', False)]</field>
        <field name="context">{}</field>
    </record>

    <record id="action_open_breed_from_pet" model="ir.actions.act_window">
        <field name="name">Breed Profile</field>
        <field name="res_model">petget.dog.breed</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

</odoo>
