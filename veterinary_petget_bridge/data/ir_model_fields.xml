    <record id="field_x_pets_petget_life_stage" model="ir.model.fields">
        <field name="name">x_petget_life_stage_id</field>
        <field name="field_description">Life Stage</field>
        <field name="model_id" ref="veterinary_clinic.x_pets_model"/>
        <field name="ttype">many2one</field>
        <field name="relation">petget.dog.life.stage</field>
        <field name="store" eval="False"/>
        <field name="depends">x_date_of_birth,x_is_dog</field>
        <field name="compute"><![CDATA[
stages = self.env['petget.dog.life.stage'].search([])
today = datetime.date.today()
for record in self:
    stage = self.env['petget.dog.life.stage']
    if record.x_is_dog and record.x_date_of_birth and record.x_date_of_birth <= today:
        weeks = (today - record.x_date_of_birth).days // 7
        for candidate in stages:
            age_from = candidate.age_from_weeks or 0
            age_to = candidate.age_to_weeks or 0
            if weeks >= age_from and (age_to == 0 or weeks < age_to):
                stage = candidate
                break
    record['x_petget_life_stage_id'] = stage.id
        ]]></field>
    </record>

