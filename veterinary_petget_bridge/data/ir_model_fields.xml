        <field name="store" eval="False"/>
        <field name="depends">x_petget_reminder_ids,x_petget_reminder_ids.state</field>
        <field name="compute"><![CDATA[
for record in self:
    count = 0
    for reminder in record.x_petget_reminder_ids:
        if reminder.state == 'pending':
            count += 1
    record['x_petget_reminder_count'] = count
        ]]></field>
    </record>

