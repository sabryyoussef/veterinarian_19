<odoo>

    <record id="field_x_pets_is_dog" model="ir.model.fields">
        <field name="name">x_is_dog</field>
        <field name="field_description">Is Dog</field>
        <field name="model_id" ref="veterinary_clinic.x_pets_model"/>
        <field name="ttype">boolean</field>
        <field name="store" eval="False"/>
        <field name="depends">x_species.x_name</field>
        <field name="compute"><![CDATA[
for record in self:
    record['x_is_dog'] = (record.x_species.x_name or '').lower() == 'dog'
        ]]></field>
    </record>

