    <record id="field_x_pets_petget_age" model="ir.model.fields">
        <field name="name">x_petget_age_display</field>
        <field name="field_description">Age</field>
        <field name="model_id" ref="veterinary_clinic.x_pets_model"/>
        <field name="ttype">char</field>
        <field name="store" eval="False"/>
        <field name="depends">x_date_of_birth</field>
        <field name="compute"><![CDATA[
today = datetime.date.today()
for record in self:
    age = ''
    dob = record.x_date_of_birth
    if dob and dob <= today:
        delta_days = (today - dob).days
        years = delta_days // 365
        months = (delta_days % 365) // 30
        age = '%dy %dm' % (years, months)
    record['x_petget_age_display'] = age
        ]]></field>
    </record>

